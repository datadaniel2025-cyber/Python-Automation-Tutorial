# ---------------------------------------------------------------------------
# COLUMN MAPPING
# Each key maps to a list of accepted Excel column names (first exact match
# wins; falls back to partial/case-insensitive). Add new aliases here if the
# source file uses different column names in future versions.
# ---------------------------------------------------------------------------
COL_MAP = {
   ###REF
}


# ---------------------------------------------------------------------------
# SCENARIO NORMALIZATION
# Raw values from the Scenario column → canonical display names used in JS.
# Add new variants here if the source file uses different spellings.
# ---------------------------------------------------------------------------
SCENARIO_NORM = {
     ###REF
}
# Display order in charts and tables — do not change without updating JS SC_COLORS too
SCENARIO_ORDER = ['3C', '3C+2C', 'What-If']

# ---------------------------------------------------------------------------
# LOB DISPLAY DESCRIPTIONS
# Maps LOB code → readable subtitle shown on product cards.
# Add new LOB codes here as new plans are introduced.
# ---------------------------------------------------------------------------
LOB_DESCS = {
     ###REF
}


# ---------------------------------------------------------------------------
# HELPERS
# ---------------------------------------------------------------------------

def find_col(df, key, col_map=None):
    """Resolve a logical key to an actual DataFrame column name.
    Tries exact match first, then partial/case-insensitive substring match.
    Pass col_map to use a mapping other than the default COL_MAP."""
    if col_map is None:
        col_map = COL_MAP
    candidates = col_map.get(key, [key])
    lower = {c.strip().lower(): c for c in df.columns}
    for cand in candidates:
        if cand.strip().lower() in lower:
            return lower[cand.strip().lower()]
    for cand in candidates:
        for lo, col in lower.items():
            if cand.strip().lower() in lo:
                return col
    return None


def norm_sc(raw):
    """Normalize raw scenario string to canonical name (e.g. '3C2C' → '3C+2C')."""
    k = str(raw).strip().upper().replace(' ', '').replace('-', '').replace('+', '').replace('_', '')
    return SCENARIO_NORM.get(k, str(raw).strip())


def is_y(series):
    """Return boolean Series — True where cell value is 'Y' (case-insensitive)."""
    return series.astype(str).str.strip().str.upper() == 'Y'


def safe_int(v):
    """Convert value to int, returning 0 on NaN or error."""
    try:
        f = float(v)
        return 0 if f != f else int(f)
    except Exception:
        return 0


def safe_float(v):
    """Convert value to float, returning 0.0 on NaN or error."""
    try:
        f = float(v)
        return 0.0 if f != f else f
    except Exception:
        return 0.0


# ---------------------------------------------------------------------------
# DATASET BUILDER
# Called twice by process_excel(): once for all rows, once for Expansion=Y only.
#
# Returns a dict with four keys:
#   products          – {state: [{label, desc, s, total, unmet, unmet_sc}]}
#   spec_data         – {state: {lob: [{name, total, '3C', '3C+2C', 'What-If'}]}}
#   county_data       – {state: {lob: [{spec, county, expansion, mbr_na, ...sc keys}]}}
#   scenarios_by_prod – {state: {lob: [list of scenario keys present for that LOB]}}
# ---------------------------------------------------------------------------

def _build_dataset(df, cols, states):
    """Build the full data payload for one dataset (all rows or expansion rows)."""
    products          = {}
    spec_data         = {}
    county_data       = {}
    scenarios_by_prod = {}

    for state in states:
        sdf  = df[df[cols['state']].astype(str) == state]
        lobs = sorted(sdf[cols['lob']].dropna().astype(str).unique())

        products[state]          = []
        spec_data[state]         = {}
        county_data[state]       = {}
        scenarios_by_prod[state] = {}

        for lob in lobs:
            ldf        = sdf[sdf[cols['lob']].astype(str) == lob]
            sc_present = [s for s in SCENARIO_ORDER if s in ldf['_sc'].values]
            scenarios_by_prod[state][lob] = sc_present

            # ── Product-level % met per scenario ──
            s_pcts = {}
            for sc in sc_present:
                scdf = ldf[ldf['_sc'] == sc]
                t = len(scdf)
                m = int(is_y(scdf[cols['met']]).sum()) if t else 0
                s_pcts[sc] = round(m / t, 4) if t else 0.0

            sc3c    = ldf[ldf['_sc'] == '3C']
            total3c = len(sc3c)
            if not total3c and '3C+2C' in ldf['_sc'].values:
                sc3c    = ldf[ldf['_sc'] == '3C+2C']
                total3c = len(sc3c)
            unmet3c = int((~is_y(sc3c[cols['met']])).sum()) if total3c else 0

            # Unmet row count per scenario (only for scenarios present in this LOB)
            unmet_sc = {}
            for sc in sc_present:
                sc_df = ldf[ldf['_sc'] == sc]
                if len(sc_df):
                    unmet_sc[sc] = int((~is_y(sc_df[cols['met']])).sum())

            products[state].append({
                'label':    lob,
                'desc':     LOB_DESCS.get(lob, lob),
                's':        s_pcts,
                'total':    total3c,
                'unmet':    unmet3c,
                'unmet_sc': unmet_sc,
            })

            # ── Specialty-level percentages ──
            specs     = sorted(ldf[cols['specialty']].dropna().astype(str).unique())
            spec_rows = []
            for spec in specs:
                spdf = ldf[ldf[cols['specialty']].astype(str) == spec]
                row  = {'name': spec, 'total': len(spdf[spdf['_sc'] == '3C'])}
                for sc in sc_present:
                    sc_sp = spdf[spdf['_sc'] == sc]
                    t = len(sc_sp)
                    m = int(is_y(sc_sp[cols['met']]).sum()) if t else 0
                    row[sc] = round(m / t, 4) if t else 0.0
                spec_rows.append(row)
            spec_data[state][lob] = spec_rows

            # ── County-level data ──
            if cols['county']:
                counties  = sorted(ldf[cols['county']].dropna().astype(str).unique())
                cnty_rows = []
                for spec in specs:
                    for county in counties:
                        mask = (
                            (ldf[cols['specialty']].astype(str) == spec) &
                            (ldf[cols['county']].astype(str)    == county)
                        )
                        cell = ldf[mask]
                        if len(cell) == 0:
                            continue

                        sc3c_cell = cell[cell['_sc'] == '3C']
                        ref       = sc3c_cell.iloc[0] if len(sc3c_cell) else cell.iloc[0]

                        row = {'spec': spec, 'county': county}
                        row['spec_code']       = str(ref[cols['spec_code']]).strip() if cols['spec_code'] and pd.notna(ref[cols['spec_code']]) else spec
                        row['expansion']       = str(ref[cols['expansion']]) if cols['expansion'] and pd.notna(ref[cols['expansion']]) else 'N'
                        row['membersBase']     = safe_int(ref[cols['unmet_mbr']]) if cols['unmet_mbr'] else 0

                        mbr_na = {}
                        met_sc = {}   # actual Met Overall value per scenario ('Y' or 'N')
                        fill_sc = {}  # actual Fillable Gap Indicator value per scenario
                        for sc in sc_present:
                            sc_cell = cell[cell['_sc'] == sc]
                            if len(sc_cell) and cols['unmet_mbr']:
                                mbr_na[sc] = safe_int(sc_cell[cols['unmet_mbr']].iloc[0])
                            else:
                                mbr_na[sc] = 0
                            if len(sc_cell) and cols['met']:
                                met_val = str(sc_cell[cols['met']].iloc[0]).strip().upper()
                                met_sc[sc] = 'Y' if met_val == 'Y' else 'N'
                            else:
                                met_sc[sc] = 'N'
                            if len(sc_cell) and cols['fillable']:
                                fv = str(sc_cell[cols['fillable']].iloc[0]).strip()
                                # treat empty, nan, none, or any all-dash value (-, --, ---) as empty
                                fill_sc[sc] = '' if (not fv.strip('- ') or fv.lower() in ('nan', 'none')) else fv
                            else:
                                fill_sc[sc] = ''
                            if len(sc_cell) and cols['pct']:
                                row[sc] = round(safe_float(sc_cell[cols['pct']].iloc[0]) / 100.0, 4)
                            elif len(sc_cell):
                                cnt = int(is_y(sc_cell[cols['met']]).sum())
                                row[sc] = round(cnt / len(sc_cell), 4)
                            else:
                                row[sc] = 0.0
                        row['mbr_na']  = mbr_na
                        row['met_sc']  = met_sc
                        row['fill_sc'] = fill_sc

                        cnty_rows.append(row)
                county_data[state][lob] = cnty_rows
            else:
                county_data[state][lob] = []

    return {
        'products':          products,
        'spec_data':         spec_data,
        'county_data':       county_data,
        'scenarios_by_prod': scenarios_by_prod,
    }




# ---------------------------------------------------------------------------
# EXCEL PROCESSOR
# Entry point: reads the file, resolves columns, builds both datasets,
# and returns the combined payload that gets injected into the HTML template.
# ---------------------------------------------------------------------------

def process_excel(filepath):
    print(f"Reading  : {filepath}")
    df = pd.read_excel(filepath, engine='openpyxl')
    df.columns = df.columns.str.strip()
    print(f"Rows     : {len(df):,}  |  Columns: {list(df.columns)}")

    cols = {k: find_col(df, k) for k in COL_MAP}
    print("\nColumn mapping:")
    for k, v in cols.items():
        print(f"  {k:<14} → {v or 'NOT FOUND'}")

    for req in ('state', 'lob', 'scenario', 'specialty', 'met'):
        if not cols[req]:
            raise ValueError(
                f"Required column '{req}' not found.\n"
                f"Tried    : {COL_MAP[req]}\n"
                f"Available: {list(df.columns)}"
            )

    df['_sc'] = df[cols['scenario']].apply(norm_sc)

    states = sorted(df[cols['state']].dropna().astype(str).unique())
    print(f"\nStates   : {states}")

    has_expansion = bool(cols['expansion'])

    print("\n── Building ALL-rows dataset ──")
    data_all = _build_dataset(df, cols, states)

    if has_expansion:
        df_exp = df[is_y(df[cols['expansion']])]
        exp_row_count = len(df_exp)
        print(f"\n── Building EXPANSION=Y dataset ({exp_row_count:,} rows) ──")
        data_exp = _build_dataset(df_exp, cols, states)
    else:
        print("\n── No Expansion column found; expansion dataset = all ──")
        data_exp = data_all

    return {
        'states':        states,
        'has_expansion': has_expansion,
        'all':           data_all,
        'expansion':     data_exp,
    }


