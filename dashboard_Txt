def generate_html(data):
    blob     = json.dumps(data, separators=(',', ':'), ensure_ascii=False)
    gen_date = date.today().strftime('%m/%d/%Y')
    return (HTML_TEMPLATE
            .replace('/*__DATA__*/', 'const DATA = ' + blob + ';')
            .replace('/*__GEN_DATE__*/', gen_date))


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]
    if not args:
        here = Path(__file__).parent
        input_path = here / 'dashboard_dataset.xlsx'
        if not input_path.exists():
            print("ERROR: Excel file not found in the folder.")
            print("Expected file: dashboard_dataset.xlsx")
            sys.exit(1)
        print(f"Auto-detected: {input_path}")
    else:
        input_path = Path(args[0])

    output_path = Path(args[1]) if len(args) >= 2 else input_path.with_name(input_path.stem + '_dashboard.html')

    if not input_path.exists():
        print(f"File not found: {input_path}")
        sys.exit(1)

    data = process_excel(input_path)
    html = generate_html(data)
    output_path.write_text(html, encoding='utf-8')
    print(f"\nDone → {output_path}  ({len(html)//1024} KB)")


if __name__ == '__main__':
    main()
