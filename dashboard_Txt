<script>
/* ══════════════════════════════════════════════════════════
   DATA — injected by generate_dashboard.py at build time.
   Structure:
     DATA.states          – sorted list of state strings
     DATA.has_expansion   – true if Excel has an Expansion column
     DATA.all             – full dataset (all rows)
     DATA.expansion       – filtered dataset (Expansion = Y rows only)
   Each dataset contains: products, spec_data, county_data, scenarios_by_prod
   ══════════════════════════════════════════════════════════ */
/*__DATA__*/

var STATES        = DATA.states;
var HAS_EXPANSION = DATA.has_expansion;

/* Active dataset pointers — reassigned by setDataset() so all renders
   automatically reflect whichever dataset is currently selected.      */
var PRODUCTS, SPEC_DATA, COUNTY_DATA, SC_BY_PROD;

// Swap all four dataset pointers at once; called on page load and toggle
function setDataset(useExpansion) {
  var d      = useExpansion ? DATA.expansion : DATA.all;
  PRODUCTS   = d.products;
  SPEC_DATA  = d.spec_data;
  COUNTY_DATA = d.county_data;
  SC_BY_PROD  = d.scenarios_by_prod;
}
setDataset(false);  /* boot with all-rows data */

/* ══════════════════════════════════════════════════════════
   EXPANSION TOGGLE
   Switches the active dataset and re-renders every visible
   section so all numbers reflect the new filter instantly.
   ══════════════════════════════════════════════════════════ */
var expansionMode = false;

function onExpansionToggle(checked) {
  expansionMode = checked;
  setDataset(checked);

  /* update toggle visual state */
  var wrap    = document.getElementById('exp-toggle-wrap');
  var lblWrap = document.getElementById('exp-lbl-wrap');
  var badge   = document.getElementById('exp-badge');
  var sub     = document.getElementById('exp-lbl-sub');
  wrap.classList.toggle('active', checked);
  lblWrap.classList.toggle('active', checked);
  badge.classList.toggle('show', checked);
  sub.textContent = checked
    ? 'Showing expansion counties only'
    : 'Showing expansion counties only';

  /* re-render whatever page is visible */
  renderStateFilter();
  renderOvLegend();
  renderProdGrid();
  if(document.getElementById('pg2').classList.contains('on')){
    buildDrill();
    if(curSubTab === 'county') renderCountyTable();
  }
}

/* ══════════════════════════════════════════════════════════
   SHARED CONSTANTS & HELPERS
   ══════════════════════════════════════════════════════════ */

// Canonical order and accent colours for each scenario
// Must match SCENARIO_ORDER / SCENARIO_NORM in generate_dashboard.py
var SCENARIO_ORDER = ['3C','3C+2C','What-If'];
var SC_COLORS = {'3C':'#28997e','3C+2C':'#d07c24','What-If':'#7553bb'};

// Returns the list of scenarios available for a given state+LOB
function getScenarios(state, lob) {
  return (SC_BY_PROD[state] && SC_BY_PROD[state][lob]) || ['3C'];
}

// Gap severity thresholds: ≥90% = met, ≥75% = moderate, ≥45% = high, else severe
function gapSev(v){
  if(v>=.90) return 'low';
  if(v>=.75) return 'moderate';
  if(v>=.45) return 'high';
  return 'severe';
}
// Derived helpers — all read from gapSev() so thresholds only need changing above
function gapLabel(v){ return {low:'Low Gap',moderate:'Moderate Gap',high:'High Gap',severe:'Severe Gap'}[gapSev(v)]; }
function gapClass(v){ return {low:'gap-low',moderate:'gap-moderate',high:'gap-high',severe:'gap-severe'}[gapSev(v)]; }
function gapDotColor(v){ return {low:'var(--green)',moderate:'var(--amber)',high:'var(--orange)',severe:'var(--rose)'}[gapSev(v)]; }
function gapBarColor(v){ return {low:'var(--green)',moderate:'var(--amber)',high:'var(--orange)',severe:'var(--rose)'}[gapSev(v)]; }
function gapKpiClass(s){ return {low:'k-low',moderate:'k-moderate',high:'k-high',severe:'k-severe'}[s]; }

// Determines the recommended fix action based on which scenario first hits 90%
function fixPath(p, scenarios){
  var v3  = p.s['3C']       || 0;
  var v32 = scenarios.includes('3C+2C')   ? (p.s['3C+2C']   || 0) : -1;
  var vwi = scenarios.includes('What-If') ? (p.s['What-If'] || 0) : -1;
  if(v3  >= .90) return {label:'Maintain',              cls:'fix-ok',   icon:'✓'};
  if(v32 >= .90) return {label:'Credential to resolve', cls:'fix-cred', icon:'📋'};
  if(vwi >= .90) return {label:'LOI needed',            cls:'fix-loi',  icon:'📝'};
  return                {label:'Needs recruitment',     cls:'fix-rec',  icon:'🚨'};
}

// Renders a multi-ring SVG donut chart. One ring per scenario, inner→outer.
// Ring radii scale automatically based on how many scenarios are present.
function donut(s, scenarios, sz) {
  sz = sz || 140;
  var cx = sz/2, cy = sz/2, n = scenarios.length;
  var rInner = sz * (n===1 ? 0.28 : n===2 ? 0.19 : 0.15);
  var rStep  = sz * (n===1 ? 0    : n===2 ? 0.14 : 0.12);
  var sw     = sz * 0.065;
  var o = '';
  scenarios.forEach(function(sc, i){
    var r   = rInner + i * rStep;
    var pct = s[sc] || 0;
    var c   = SC_COLORS[sc];
    var ci  = 2 * Math.PI * r;
    var d   = (ci * pct).toFixed(2);
    var g   = (ci * (1-pct)).toFixed(2);
    var off = (ci * .25).toFixed(2);
    o += '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="#ede8e0" stroke-width="'+sw+'"/>';
    o += '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="'+c+'" stroke-width="'+sw
       +'" stroke-dasharray="'+d+' '+g+'" stroke-dashoffset="'+off+'" stroke-linecap="round"/>';
  });
  return '<svg width="'+sz+'" height="'+sz+'" viewBox="0 0 '+sz+' '+sz+'">'+o+'</svg>';
}

/* ══════════════════════════════════════════════════════════
   PAGE 1 — OVERVIEW
   State filter pills → product card grid with donut rings.
   curState holds the currently selected state pill.
   ══════════════════════════════════════════════════════════ */
var curState = STATES[0] || '';

// Renders the state pill buttons; highlights the active state
function renderStateFilter(){
  document.getElementById('state-filter').innerHTML =
    STATES.map(function(s){
      return '<button class="pill'+(s===curState?' on':'')+'" onclick="setOvState(\''+s+'\')">'+s+'</button>';
    }).join('');
}

function setOvState(s){ curState=s; renderStateFilter(); renderOvLegend(); renderProdGrid(); }

// Builds the colour-coded scenario legend strip from whichever scenarios are present in the state
function renderOvLegend(){
  var seen = [];
  (PRODUCTS[curState]||[]).forEach(function(p){
    getScenarios(curState, p.label).forEach(function(sc){
      if(!seen.includes(sc)) seen.push(sc);
    });
  });
  var scenarios = SCENARIO_ORDER.filter(function(s){ return seen.includes(s); });
  var parts = scenarios.map(function(sc){
    return '<div class="leg"><span class="leg-d" style="background:'+SC_COLORS[sc]+'"></span>'+sc+'</div>';
  });
  document.getElementById('ov-legend').innerHTML = parts.join('<div class="leg-sep"></div>');
}

// Renders all product cards for the active state; each card has a donut + scenario breakdown
function renderProdGrid(){
  var st    = curState;
  var prods = PRODUCTS[st] || [];
  var lbl   = expansionMode ? 'Product Cards — '+st+' (Expansion = Y only)' : 'Product Cards — '+st;
  document.getElementById('prod-sec-lbl').textContent = lbl;

  document.getElementById('prod-grid').innerHTML = prods.map(function(p, i){
    var v3        = p.s['3C'] || 0;
    var scenarios = getScenarios(st, p.label);
    var uc        = p.unmet || 0;
    var fp        = fixPath(p, scenarios);
    var gc        = gapClass(v3);
    var barC      = gapBarColor(v3);

    // Critical specialty gap detection.
    // Uses the first available scenario in order (3C → 3C+2C → What-If)
    // so cards still show alerts even when 3C is absent for that product.
    var critSc   = scenarios[0] || '3C';
    var cntyRows = (COUNTY_DATA[st] && COUNTY_DATA[st][p.label]) || [];

    function countCritGap(specTest){
      return cntyRows.filter(function(r){
        if(!r.spec || !r.met_sc) return false;
        var s = r.spec.toLowerCase();
        return specTest(s) && r.met_sc[critSc] === 'N';
      }).length;
    }
    // Pediatric: ONLY matches the bare word "Pediatric/Pediatrics" (e.g. specialty = "Pediatric")
    //            OR specialty contains BOTH "pediatric" AND "primary" (e.g. "Pediatric Primary Care")
    //            "Pediatrics Sub", "Pediatric Density", etc. do NOT qualify.
    // PCP: contains "primary care" but NOT "pediatric" (those belong to Pediatric group)
    // OB/GYN: contains "ob/gyn", "ob-gyn", or "ob gyn"
    var cntHospital  = countCritGap(function(s){ return s.includes('inpatient hospital'); });
    var cntPCP       = countCritGap(function(s){ return s.includes('primary care') && !s.includes('pediatric'); });
    var cntOBGYN     = countCritGap(function(s){ return s.includes('ob/gyn') || s.includes('ob-gyn') || s.includes('ob gyn'); });
    var cntPediatric = countCritGap(function(s){
      var pedOnly        = /^pediatrics?$/.test(s.trim());
      var pedWithPrimary = s.includes('pediatric') && s.includes('primary');
      return (pedOnly || pedWithPrimary) && !s.includes('density');
    });

    var scRows = scenarios.map(function(k){
      var v = p.s[k] || 0;
      return '<div class="pc-sc-row">'
        +'<div class="pc-sc-top">'
        +'<div class="pc-sc-name"><span class="pc-sc-dot" style="background:'+SC_COLORS[k]+'"></span>'+k+'</div>'
        +'<span class="pc-sc-pct" style="color:'+SC_COLORS[k]+'">'+(v*100).toFixed(1)+'%</span>'
        +'</div>'
        +'<div class="pc-sc-track"><div class="pc-sc-fill" style="width:'+(v*100)+'%;background:'+SC_COLORS[k]+'"></div></div>'
        +'</div>';
    }).join('');

    return '<div class="prod-card" style="animation-delay:'+(i*.06)+'s" onclick="goDrill(\''+st+'\','+i+')">'
      +'<div class="pc-bar" style="background:'+barC+'"></div>'
      +'<div class="pc-gap-banner">'
      +'<span class="pc-gap-badge '+gc+'">'+gapLabel(v3)+'</span>'
      +'<span class="pc-unmet"><span>'+uc.toLocaleString()+'</span> Open Gaps</span>'
      +'</div>'
      +'<div class="pc-head"><div>'
      +'<div class="pc-name">'+p.label+'</div>'
      +'<div class="pc-desc">'+p.desc+'</div>'
      +'<div class="pc-go">View specialty detail →</div>'
      +'</div><span class="pc-state">'+st+'</span></div>'
      +'<div class="pc-donut-area">'
      +'<div class="pc-dw">'+donut(p.s, scenarios, 140)
      +'<div class="pc-dc">'
      +'<div class="pc-dc-v" style="color:'+barC+'">'+(v3*100).toFixed(0)+'%</div>'
      +'<div class="pc-dc-l">3C</div>'
      +'</div></div>'
      +'<div class="pc-sc-list">'+scRows+'</div>'
      +'</div>'
      +'<div class="pc-foot">'
      +'<span class="pc-combos">'+(p.total||0).toLocaleString()+' Total 3C Specialty-County Combos</span>'
      +'<span class="fix-path '+fp.cls+'">'+fp.icon+' '+fp.label+'</span>'
      +'</div>'
      +(function(){
          var tags = [];
          if(cntHospital)  tags.push(['Hospital',  cntHospital]);
          if(cntPCP)       tags.push(['PCP',        cntPCP]);
          if(cntOBGYN)     tags.push(['OB/GYN',     cntOBGYN]);
          if(cntPediatric) tags.push(['Pediatric',  cntPediatric]);
          if(!tags.length) return '';
          return '<div class="pc-crit-alert">'
            +'<span class="pc-crit-hd">⚠ Critical ('+critSc+') — Major Specialty Not Meeting Adequacy:</span>'
            +tags.map(function(t){
              return '<span class="pc-crit-tag">'+t[0]
                +'<span class="pc-crit-cnt">('+t[1]+' combo'+(t[1]===1?'':'s')+')</span>'
                +'</span>';
            }).join('')
            +'</div>';
        }())
      +'</div>';
  }).join('');
}

/* ══════════════════════════════════════════════════════════
   PAGE 2 — DRILL-DOWN
   Two sub-tabs: Specialty Gap Analysis | County Performance.
   curProd   = index into PRODUCTS[curState]
   curSubTab = 'spec' | 'county'
   curScView = 'all' | '3C' | '3C+2C' | 'What-If'
   ══════════════════════════════════════════════════════════ */
var curProd   = 0;
var curSubTab = 'spec';
var curScView = 'all';

// Navigate from overview card click to drill-down page
function goDrill(state, prodIdx){
  curState=state; curProd=prodIdx; curSubTab='spec'; curScView='all';
  ['spec','county'].forEach(function(t){
    document.getElementById('st-'+t).classList.toggle('on', t==='spec');
    document.getElementById('sp-'+t).classList.toggle('on', t==='spec');
  });
  document.querySelectorAll('.sc-view-btn').forEach(function(b,i){ b.classList.toggle('on',i===0); });
  buildDrill();
  switchPage('pg2');
}

// Builds the entire drill-down page: breadcrumb, KPI tiles, legend, chart header
function buildDrill(){
  var st        = curState;
  var prod      = (PRODUCTS[st]||[])[curProd];
  if(!prod) return;
  var scenarios = getScenarios(st, prod.label);

  document.getElementById('bc-txt').textContent   = st+' · '+prod.label;
  document.getElementById('dr-title').textContent = st+' — '+prod.label+(expansionMode?' (Expansion = Y)':'');
  document.getElementById('dr-sub').textContent   = prod.desc+' · Specialty-level gap analysis by scenario';
  document.getElementById('nb-dr-lbl').textContent= 'Detail';

  document.getElementById('prod-switcher').innerHTML =
    '<span class="pill-lbl">Product</span>'+
    (PRODUCTS[st]||[]).map(function(p,i){
      return '<button class="pill'+(i===curProd?' on':'')+'" onclick="switchDrillProd('+i+')">'+p.label+'</button>';
    }).join('');

  var specs      = (SPEC_DATA[st]&&SPEC_DATA[st][prod.label]) || [];
  var totalUnmet = prod.unmet || 0;
  var unmetSc    = prod.unmet_sc || {};

  function fmtUnmet(sc){
    if(!scenarios.includes(sc)) return 'N/A';
    var v = unmetSc[sc];
    return v !== undefined ? v.toLocaleString() : '0';
  }

  /* Fixable by Credentialing = -(Unmet(3C+2C) − Unmet(3C))
     positive result → fewer unmet with credentialing → show as +N (green)
     negative result → more unmet with credentialing  → show as -N (red)   */
  var credVal, credColor, credSub;
  if(!scenarios.includes('3C+2C')){
    credVal   = 'N/A';
    credColor = null;
    credSub   = 'Scenario not available for this product';
  } else {
    var u32c      = unmetSc['3C+2C'] !== undefined ? unmetSc['3C+2C'] : 0;
    var reduction = totalUnmet - u32c;          /* = -(u32c - totalUnmet) */
    if(reduction > 0){
      credVal   = '+' + reduction.toLocaleString();
      credColor = 'var(--green)';
      credSub   = 'Fewer unmet combos gained through credentialing';
    } else if(reduction < 0){
      credVal   = reduction.toLocaleString();   /* JS already prefixes minus */
      credColor = 'var(--rose)';
      credSub   = 'More unmet combos compared to 3C baseline';
    } else {
      credVal   = '0';
      credColor = 'var(--text3)';
      credSub   = 'No change from credentialing';
    }
  }

  document.getElementById('dr-kpis').innerHTML = [
    {lbl:'Unmet Combos (3C)',       val:totalUnmet.toLocaleString(), c:'cr',       sub:'Rows where Met Overall = N on 3C',      k:'k-severe'},
    {lbl:'Unmet Combos (3C & 2C)',  val:fmtUnmet('3C+2C'),          c:'co',       sub:'Rows where Met Overall = N on 3C+2C',  k:'k-high'},
    {lbl:'Unmet Combos (What-If)',  val:fmtUnmet('What-If'),        c:'ca',       sub:'Rows where Met Overall = N on What-If',k:'k-moderate'},
    {lbl:'Fixable by Credentialing',val:credVal,                    c:'_cred',    sub:credSub,                                k:'k-low'},
  ].map(function(k,i){
    var isNA   = k.val === 'N/A';
    var isCred = k.c  === '_cred';
    var valEl;
    if(isNA){
      valEl = '<div class="kpi-val" style="font-family:\'Sora\',sans-serif;font-size:.95rem;font-weight:600;color:var(--text3)">N/A</div>';
    } else if(isCred){
      valEl = '<div class="kpi-val" style="color:'+(credColor||'var(--text3)')+'">'+k.val+'</div>';
    } else {
      valEl = '<div class="kpi-val '+k.c+'">'+k.val+'</div>';
    }
    var subTxt = (isNA && !isCred) ? 'Scenario not available for this product' : k.sub;
    return '<div class="kpi-tile '+k.k+'" style="animation-delay:'+(i*.04)+'s">'
      +'<div class="kpi-lbl">'+k.lbl+'</div>'
      +valEl
      +'<div class="kpi-sub">'+subTxt+'</div></div>';
  }).join('');

  var legParts = scenarios.map(function(sc){
    var desc = sc==='3C'?'current contracted network':sc==='3C+2C'?'includes credentialing pipeline':'includes LOI pipeline';
    return '<div class="leg"><span class="leg-d" style="background:'+SC_COLORS[sc]+'"></span>'+sc+' — '+desc+'</div>';
  });
  legParts.push('<div class="leg"><span class="leg-d" style="background:var(--unmet);border:1px solid var(--border)"></span>Still unmet</div>');
  document.getElementById('dr-legend').innerHTML = legParts.join('<div class="leg-sep"></div>');

  document.getElementById('chart-hd').textContent = prod.label+' · '+st+' — Specialty Overview by Scenario';
  renderStackedBar();
}

// Switch to a different product within the same state on the drill-down page
function switchDrillProd(i){
  curProd=i; curScView='all';
  document.querySelectorAll('.sc-view-btn').forEach(function(b,idx){ b.classList.toggle('on',idx===0); });
  buildDrill();
  if(curSubTab === 'county') renderCountyTable();
}

// Filter the specialty bar chart to show one scenario or all
function setScView(btn){
  curScView=btn.dataset.sc;
  document.querySelectorAll('.sc-view-btn').forEach(function(b){ b.classList.remove('on'); });
  btn.classList.add('on');
  renderStackedBar();
}

// Renders the horizontal stacked bar chart for all specialties in the current product
function renderStackedBar(){
  var st        = curState;
  var prod      = (PRODUCTS[st]||[])[curProd];
  if(!prod) return;
  var scenarios = getScenarios(st, prod.label);
  var specs     = (SPEC_DATA[st]&&SPEC_DATA[st][prod.label]) || [];
  var mode      = (curScView==='all'||scenarios.includes(curScView)) ? curScView : 'all';
  var showAll   = mode==='all';

  document.querySelectorAll('.sc-view-btn').forEach(function(btn){
    var sc=btn.dataset.sc;
    btn.style.display=(sc==='all'||scenarios.includes(sc))?'':'none';
  });

  var gridTpl = '180px 1fr';

  var legItems = showAll
    ? scenarios.map(function(sc){
        return '<div class="bar-leg"><div class="bar-leg-sw" style="background:'+SC_COLORS[sc]+'"></div>'+sc+'</div>';
      }).join('')+'<div class="bar-leg"><div class="bar-leg-sw" style="background:var(--unmet);border:1px solid var(--border)"></div>Unmet</div>'
    : '<div class="bar-leg"><div class="bar-leg-sw" style="background:'+SC_COLORS[mode]+'"></div>'+mode+'</div>'
      +'<div class="bar-leg"><div class="bar-leg-sw" style="background:var(--unmet);border:1px solid var(--border)"></div>Unmet</div>';

  var html = '<div class="sbt-hdr"><div style="display:grid;grid-template-columns:'+gridTpl+';align-items:center">'
    +'<div class="col-lbl">Specialty</div>'
    +'<div class="col-bar-hdr">'+legItems+'</div>'
    +'</div></div>';

  specs.forEach(function(sp){
    var v3     = sp['3C'] || 0;
    var sevDot = '<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:'+gapDotColor(v3)+';flex-shrink:0;margin-right:4px"></span>';
    var barHtml='';

    if(showAll){
      var segs=[]; var prev=0;
      scenarios.forEach(function(sc,i){
        var v=sp[sc]||0;
        if(i===0){ segs.push({sc:sc,w:v*100,lbl:(v*100).toFixed(0)+'%'}); prev=v; }
        else{ var inc=Math.max(0,v-prev); segs.push({sc:sc,w:inc*100,lbl:(inc*100).toFixed(0)+'%'}); if(v>prev)prev=v; }
      });
      var bestPct=Math.max.apply(null,scenarios.map(function(sc){ return sp[sc]||0; }))*100;
      var unmet=Math.max(0,100-bestPct);
      var cursor=0;
      var labels=segs.map(function(seg){
        var mid=cursor+seg.w/2; cursor+=seg.w;
        return seg.w>1.5?'<span class="bar-lbl-tag" style="left:'+mid.toFixed(1)+'%">'+seg.lbl+'</span>':'';
      }).join('');
      barHtml='<div class="stacked-bar"><div class="bar-lbl-overlay">'+labels+'</div>'
        +segs.map(function(seg){ return seg.w>0.2?'<div class="seg" style="width:'+seg.w.toFixed(2)+'%;background:'+SC_COLORS[seg.sc]+'"></div>':''; }).join('')
        +(unmet>0.5?'<div class="seg" style="flex:1;background:var(--unmet)"></div>':'')+'</div>';
    } else {
      var v=sp[mode]||0; var pct=v*100; var col=SC_COLORS[mode]; var mid=pct/2;
      barHtml='<div class="stacked-bar"><div class="bar-lbl-overlay"><span class="bar-lbl-tag" style="left:'+mid.toFixed(1)+'%">'+pct.toFixed(0)+'%</span></div>'
        +'<div class="seg" style="width:'+pct.toFixed(2)+'%;background:'+col+'"></div>'
        +((100-pct)>0.5?'<div class="seg" style="flex:1;background:var(--unmet)"></div>':'')+'</div>';
    }
    html+='<div class="sbt-row"><div style="display:grid;grid-template-columns:'+gridTpl+';align-items:center;padding:4px 0">'
      +'<div class="spec-label">'+sevDot+sp.name+'</div>'
      +'<div class="bar-wrap">'+barHtml+'</div>'+'</div></div>';
  });
  document.getElementById('sbt').innerHTML=html;
}

/* ══════════════════════════════════════════════════════════
   COUNTY GAP & ACCESS DETAIL TAB
   countyRows   = raw rows for current state+LOB from COUNTY_DATA
   curCmpMode   = key into CMP_MODES ('3c-vs-32c' etc.)
   CMP_MODES    = defines which scenarios are base vs compare,
                  their display colours, and which scenarios
                  must exist for that mode to be available.
   ══════════════════════════════════════════════════════════ */
var countyRows=[], curCmpMode='';

// Add new compare combinations here if more scenarios are introduced
var CMP_MODES = {
  '3c-vs-32c': {baseKey:'3C',    cmpKey:'3C+2C',  baseColor:'var(--c3c)', cmpColor:'var(--c32c)',baseLabel:'3C % Access',   cmpLabel:'3C+2C % Access',  needs:['3C+2C']},
  '32c-vs-wif':{baseKey:'3C+2C', cmpKey:'What-If',baseColor:'var(--c32c)',cmpColor:'var(--cwif)',baseLabel:'3C+2C % Access',cmpLabel:'What-If % Access',needs:['3C+2C','What-If']},
  '3c-vs-wif': {baseKey:'3C',    cmpKey:'What-If',baseColor:'var(--c3c)', cmpColor:'var(--cwif)',baseLabel:'3C % Access',   cmpLabel:'What-If % Access',needs:['What-If']},
};

// Renders compare mode buttons; hides modes whose required scenarios are absent
function renderCmpButtons(scenarios){
  document.getElementById('cmp-btns').innerHTML = Object.keys(CMP_MODES).map(function(key){
    var m=CMP_MODES[key];
    if(!m.needs.every(function(s){ return scenarios.includes(s); })) return '';
    return '<button class="cmp-btn'+(key===curCmpMode?' on':'')+'" data-cmp="'+key+'" onclick="setCmpMode(this)" style="margin-right:6px">'
      +'<span style="color:'+m.baseColor+'">'+m.baseKey+'</span> vs <span style="color:'+m.cmpColor+'">'+m.cmpKey+'</span>'
      +'</button>';
  }).join('');
}

// Called when user clicks a compare button — updates table and KPI cards
function setCmpMode(btn){
  curCmpMode=btn.dataset.cmp;
  document.querySelectorAll('#cmp-btns .cmp-btn').forEach(function(b){ b.classList.remove('on'); });
  btn.classList.add('on');
  resetColFilters();
  buildCountyTable(countyRows);
  renderCountyKPIs();
}

// Tracks the active single scenario (null when in multi-scenario compare mode)
var curSingleSc = null;

// Entry point for the county sub-tab: loads rows and triggers table + KPI render
function _esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function _escAttr(s){ return _esc(s).replace(/"/g,'&quot;'); }

function renderCountyTable(){
  var st=curState, prod=(PRODUCTS[st]||[])[curProd];
  if(!prod) return;
  var scenarios=getScenarios(st,prod.label);
  document.getElementById('county-hd-title').textContent=prod.label+' · County Gap & Access Detail';
  document.getElementById('county-hd-sub').textContent=st+' · '+prod.desc+(expansionMode?' (Expansion = Y only)':'');
  countyRows=(COUNTY_DATA[st]&&COUNTY_DATA[st][prod.label])||[];
  document.getElementById('county-search-input').value='';
  resetColFilters();

  if(scenarios.length === 1){
    // Single scenario — hide compare buttons, show simplified table
    curSingleSc = scenarios[0];
    document.getElementById('cmp-btns').innerHTML =
      '<span style="font-size:.68rem;color:var(--text3);font-style:italic">Single scenario — no comparison available</span>';
    buildSingleScenarioTable(countyRows, curSingleSc);
    renderCountyKPIs();
    return;
  }

  // Multi-scenario compare mode
  curSingleSc = null;
  var validModes=Object.keys(CMP_MODES).filter(function(key){
    return CMP_MODES[key].needs.every(function(s){ return scenarios.includes(s); });
  });
  if(!validModes.includes(curCmpMode)) curCmpMode=validModes[0]||'3c-vs-32c';
  renderCmpButtons(scenarios);
  buildCountyTable(countyRows);
  renderCountyKPIs();
}

// Column-level filter state; reset whenever compare mode or product changes
var colFilters={county:'',spec:'',expansion:'all',baseStatus:'all',cmpStatus:'all',gapResult:'all',fillInd:'all'};
function resetColFilters(){ colFilters={county:'',spec:'',expansion:'all',baseStatus:'all',cmpStatus:'all',gapResult:'all',fillInd:'all'}; }

// Gap outcome uses actual Met Overall value (bMet/cMet = 'Y'/'N') for met conditions;
// falls back to % comparison for direction (improved/declined/no change)
function gapResult(bV,cV,bMet,cMet){
  if(bMet==='Y'&&cMet==='Y')    return {label:'Already Met',          cls:'gr-met'};
  if(bMet==='N'&&cMet==='Y')    return {label:'Closed',               cls:'gr-closed'};
  if(cV>bV)                     return {label:'Improved, Still Open',  cls:'gr-improved'};
  if(bV===0&&cV===0)            return {label:'No Access',             cls:'gr-noaccess'};
  if(Math.abs(cV-bV)<0.0001)   return {label:'No Change',             cls:'gr-nochange'};
  return                               {label:'Declined',              cls:'gr-declined'};
}
// Used only for KPI tile counts — based on met_sc Y/N
function fillableInd(bV,cV,bMet,cMet){
  if(bMet==='Y') return null;
  if(cMet==='Y') return {label:'Fillable by single provider',   cls:'fill-single'};
  if(cV>bV)      return {label:'Increase in access by single provider',cls:'fill-increase'};
  return null;
}

// Builds the Fillable Indicator cell content for the table column.
// Logic:
//   Both met_sc = Y            → —
//   At least one N, read fill_sc for each N scenario:
//     both empty               → —
//     both same value          → show value once
//     both different values    → (BaseKey) val1; (CmpKey) val2
//     only one has value       → show that value
function buildFillableDisplay(r, m){
  var bMet=r.met_sc?(r.met_sc[m.baseKey]||'N'):'N';
  var cMet=r.met_sc?(r.met_sc[m.cmpKey] ||'N'):'N';
  if(bMet==='Y'&&cMet==='Y') return '<span class="fill-none">—</span>';
  var fs=r.fill_sc||{};
  var bVal=(bMet==='N')?(fs[m.baseKey]||''):'';
  var cVal=(cMet==='N')?(fs[m.cmpKey] ||''):'';
  if(!bVal&&!cVal) return '<span class="fill-none">—</span>';
  var bC=SC_COLORS[m.baseKey]||'var(--teal)', cC=SC_COLORS[m.cmpKey]||'var(--amber)';
  var sty='font-size:.65rem;font-weight:600;line-height:1.6';
  // same value in both — show scenario prefix + value once
  if(bVal&&cVal&&bVal.toLowerCase()===cVal.toLowerCase())
    return '<span style="'+sty+'"><span style="color:'+bC+';">('+m.baseKey+')</span> '+bVal+'</span>';
  // different values — show both with their scenario prefix
  if(bVal&&cVal)
    return '<span style="'+sty+'">'
      +'<span style="color:'+bC+';">('+m.baseKey+')</span> '+bVal+'; '
      +'<span style="color:'+cC+';">('+m.cmpKey+')</span> '+cVal+'</span>';
  // only one has value — still show the scenario it belongs to
  if(bVal)
    return '<span style="'+sty+'"><span style="color:'+bC+';">('+m.baseKey+')</span> '+bVal+'</span>';
  return '<span style="'+sty+'"><span style="color:'+cC+';">('+m.cmpKey+')</span> '+cVal+'</span>';
}

// Applies all active column filters to the county rows array
function applyColFilters(rows){
  var m=CMP_MODES[curCmpMode]; if(!m) return rows;
  return rows.filter(function(r){
    var base=r[m.baseKey]||0,cmp=r[m.cmpKey]||0;
    var bMet=r.met_sc?(r.met_sc[m.baseKey]||'N'):(base>=.90?'Y':'N');
    var cMet=r.met_sc?(r.met_sc[m.cmpKey] ||'N'):(cmp >=.90?'Y':'N');
    var gr=gapResult(base,cmp,bMet,cMet);
    if(colFilters.county&&!r.county.toLowerCase().includes(colFilters.county.toLowerCase())) return false;
    if(colFilters.spec&&!r.spec.toLowerCase().includes(colFilters.spec.toLowerCase()))       return false;
    if(colFilters.expansion!=='all'&&r.expansion!==colFilters.expansion)                     return false;
    if(colFilters.baseStatus!=='all'&&bMet!==colFilters.baseStatus)                          return false;
    if(colFilters.cmpStatus!=='all'&&cMet!==colFilters.cmpStatus)                            return false;
    if(colFilters.gapResult!=='all'&&gr.label!==colFilters.gapResult)                        return false;
    if(colFilters.fillInd!=='all'){
      var fs=r.fill_sc||{};
      var bFill=(bMet==='N')?(fs[m.baseKey]||''):'';
      var cFill=(cMet==='N')?(fs[m.cmpKey]||''):'';
      if(colFilters.fillInd==='none'){ if(bFill||cFill) return false; }
      else{ var fi=colFilters.fillInd.toLowerCase(); if(!bFill.toLowerCase().includes(fi)&&!cFill.toLowerCase().includes(fi)) return false; }
    }
    return true;
  });
}

function renderCountyKPIs(){
  var el=document.getElementById('county-kpi-row');
  if(!el){ return; }

  // ── Single scenario mode ────────────────────────────────
  if(curSingleSc){
    var sc=curSingleSc, scColor=SC_COLORS[sc]||'var(--teal)';
    var mbrTotal=0, metCount=0, unmetCount=0;
    countyRows.forEach(function(r){
      var metVal=r.met_sc?(r.met_sc[sc]||'N'):(r[sc]>=.90?'Y':'N');
      if(metVal==='Y'){ metCount++; }
      else { unmetCount++; mbrTotal+=(r.mbr_na?(r.mbr_na[sc]||0):(r.membersBase||0)); }
    });
    var tiles=[
      {lbl:'Members w/o Access ('+sc+')',   val:mbrTotal.toLocaleString(),   color:scColor,        k:'k-severe',
       sub:sc+' total members without access across all counties'},
      {lbl:'Counties Meeting Standard',      val:metCount.toLocaleString(),   color:'var(--green)', k:'k-low',
       sub:'County+specialty combos where '+sc+' Met Overall = Y'},
      {lbl:'Counties Not Meeting Standard',  val:unmetCount.toLocaleString(), color:'var(--rose)',  k:'k-high',
       sub:'County+specialty combos where '+sc+' Met Overall = N'},
    ];
    el.style.gridTemplateColumns='repeat(3,1fr)';
    el.innerHTML=tiles.map(function(t,i){
      return '<div class="kpi-tile '+t.k+'" style="animation-delay:'+(i*.04)+'s">'
        +'<div class="kpi-lbl">'+t.lbl+'</div>'
        +'<div class="kpi-val" style="color:'+t.color+'">'+t.val+'</div>'
        +'<div class="kpi-sub">'+t.sub+'</div></div>';
    }).join('');
    return;
  }

  // ── Multi-scenario compare mode ─────────────────────────
  var m=CMP_MODES[curCmpMode];
  if(!m){ el.innerHTML=''; return; }
  var baseTotal=0, cmpTotal=0, fillSingle=0, fillIncrease=0;
  countyRows.forEach(function(r){
    var na=r.mbr_na||{};
    baseTotal+=na[m.baseKey]||0;
    cmpTotal +=na[m.cmpKey] ||0;
    var bMet=r.met_sc?(r.met_sc[m.baseKey]||'N'):'N';
    var cMet=r.met_sc?(r.met_sc[m.cmpKey] ||'N'):'N';
    var fi=fillableInd(r[m.baseKey]||0, r[m.cmpKey]||0, bMet, cMet);
    if(fi){
      if(fi.cls==='fill-single')        fillSingle++;
      else if(fi.cls==='fill-increase') fillIncrease++;
    }
  });
  var gained=baseTotal-cmpTotal;  /* positive = more members now have access in compare scenario */
  var gainedStr=gained===0?'0':gained>0?'+'+gained.toLocaleString():gained.toLocaleString();
  var gainedColor=gained>0?'var(--green)':gained<0?'var(--rose)':'var(--text3)';
  var tiles=[
    {lbl:'Members w/o Access ('+m.baseKey+')',    val:baseTotal.toLocaleString(),    color:m.baseColor,       k:'k-severe',
     sub:m.baseKey+' scenario — members still without access'},
    {lbl:'Members w/o Access ('+m.cmpKey+')',     val:cmpTotal.toLocaleString(),     color:m.cmpColor,        k:'k-high',
     sub:m.cmpKey+' scenario — members still without access'},
    {lbl:'Members Gained Access',                 val:gainedStr,                     color:gainedColor,        k:'k-low',
     sub:'Additional members with access in '+m.cmpKey+' vs '+m.baseKey+' (positive = improvement)'},
    {lbl:'Fillable by Single Provider',            val:fillSingle.toLocaleString(),   color:'var(--green)',    k:'k-low',
     sub:'Base <90% → Compare ≥90% with one provider'},
    {lbl:'Increase in Access by Single Provider',  val:fillIncrease.toLocaleString(),color:'var(--amber)',    k:'k-moderate',
     sub:'Base <90%, Compare improves but stays <90%'},
  ];
  el.style.gridTemplateColumns='repeat(5,1fr)';
  el.innerHTML=tiles.map(function(t,i){
    return '<div class="kpi-tile '+t.k+'" style="animation-delay:'+(i*.04)+'s">'
      +'<div class="kpi-lbl">'+t.lbl+'</div>'
      +'<div class="kpi-val" style="color:'+t.color+'">'+t.val+'</div>'
      +'<div class="kpi-sub">'+t.sub+'</div></div>';
  }).join('');
}

// Renders a simple single-scenario table (no compare, no delta, no gap result)
