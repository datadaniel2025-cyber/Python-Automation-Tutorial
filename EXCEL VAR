def _make_settings_page(parent, plans, tp, is_qhp=False):
    """Builds a settings sub-page into parent frame.
    tp       = settings key prefix: '' for DSNP, 'qhp_' for QHP
    is_qhp   = True adds the Plan/Category Row spinbox
    Returns (template_vars, save_path_vars, header_row_vars, category_row_vars)
    """
    frame = tk.Frame(parent, bg=C_WHITE, padx=24, pady=20)
    frame.columnconfigure(1, weight=1)

    tk.Label(frame, text="Report Templates", bg=C_WHITE,
             font=("Segoe UI", 11, "bold"), fg=C_NAVY).grid(
        row=0, column=0, columnspan=4, sticky="w", pady=(0, 4))
    tk.Label(frame,
             text="Select the template file and header row for each plan. Saved automatically.",
             bg=C_WHITE, fg="#6680AA", font=("Segoe UI", 8, "italic")).grid(
        row=1, column=0, columnspan=4, sticky="w", pady=(0, 14))

    t_vars   = {}
    sp_vars  = {}
    hr_vars  = {}
    cat_vars = {}

    def _save_row(plan, var, field):
        try:
            settings[tp + field][plan] = int(var.get())
            save_settings(settings)
        except ValueError:
            pass

    def _browse_tmpl(plan):
        path = filedialog.askopenfilename(
            title=f"Select {plan} Template File",
            filetypes=[("Excel files", "*.xlsx *.xls"), ("All files", "*.*")])
        if path:
            t_vars[plan].set(path)
            settings[tp + "templates"][plan] = path
            save_settings(settings)

    def _browse_save(plan):
        folder = filedialog.askdirectory(title=f"Select Report Save Location for {plan}")
        if folder:
            sp_vars[plan].set(folder)
            settings[tp + "save_paths"][plan] = folder
            save_settings(settings)

    gr = 2
    for plan in plans:
        tk.Label(frame, text=plan, bg=C_WHITE,
                 font=("Segoe UI", 9, "bold"), fg=C_NAVY).grid(
            row=gr, column=0, columnspan=4, sticky="w", pady=(10, 2))
        gr += 1

        # Template path
        tk.Label(frame, text="Template:", bg=C_WHITE,
                 font=("Segoe UI", 9)).grid(row=gr, column=0, sticky="w", padx=(12, 8))
        sv = settings[tp + "templates"].get(plan, "")
        tv = tk.StringVar(value=sv if sv else "No file selected")
        t_vars[plan] = tv
        tk.Label(frame, textvariable=tv, bg="white", fg="#333",
                 font=("Segoe UI", 9), anchor="w", relief="solid",
                 width=38, padx=6).grid(row=gr, column=1, sticky="ew", ipady=4, padx=(0, 6))
        tk.Button(frame, text="Browse", command=lambda p=plan: _browse_tmpl(p),
                  bg=C_NAVY, fg=C_WHITE, font=("Segoe UI", 9, "bold"),
                  relief="flat", padx=8, cursor="hand2",
                  activebackground=C_DKNAV, activeforeground=C_WHITE
                  ).grid(row=gr, column=2, ipady=4, columnspan=2)
        gr += 1

        # Save path
        tk.Label(frame, text="Save Path:", bg=C_WHITE,
                 font=("Segoe UI", 9)).grid(row=gr, column=0, sticky="w", padx=(12, 8))
        ss = settings[tp + "save_paths"].get(plan, "")
        spv = tk.StringVar(value=ss if ss else "No folder selected")
        sp_vars[plan] = spv
        tk.Label(frame, textvariable=spv, bg="white", fg="#333",
                 font=("Segoe UI", 9), anchor="w", relief="solid",
                 width=38, padx=6).grid(row=gr, column=1, sticky="ew", ipady=4, padx=(0, 6))
        tk.Button(frame, text="Browse", command=lambda p=plan: _browse_save(p),
                  bg=C_NAVY, fg=C_WHITE, font=("Segoe UI", 9, "bold"),
                  relief="flat", padx=8, cursor="hand2",
                  activebackground=C_DKNAV, activeforeground=C_WHITE
                  ).grid(row=gr, column=2, ipady=4, columnspan=2)
        gr += 1

        # Header row (specialty header row for QHP, prac/fac for DSNP)
        default_hr = 6 if is_qhp else 4
        hr_lbl     = "Specialty Header Row:" if is_qhp else "Prac & Fac Header Row:"
        saved_hr   = settings[tp + "header_rows"].get(plan, default_hr)
        hrv = tk.IntVar(value=saved_hr)
        hr_vars[plan] = hrv
        rsub = tk.Frame(frame, bg=C_WHITE)
        rsub.grid(row=gr, column=0, columnspan=4, sticky="w", padx=(12, 0), pady=(4, 2))
        tk.Label(rsub, text=hr_lbl, bg=C_WHITE, font=("Segoe UI", 9)).pack(side="left")
        hrs = tk.Spinbox(rsub, from_=1, to=50, width=4, textvariable=hrv,
                         font=("Segoe UI", 9),
                         command=lambda p=plan, v=hrv: _save_row(p, v, "header_rows"))
        hrs.pack(side="left", padx=(4, 0))
        hrs.bind("<FocusOut>", lambda e, p=plan, v=hrv: _save_row(p, v, "header_rows"))
        hrs.bind("<Return>",   lambda e, p=plan, v=hrv: _save_row(p, v, "header_rows"))
        gr += 1

        # Category row — QHP only
        if is_qhp:
            saved_cat = settings[tp + "category_rows"].get(plan, 5)
            catv = tk.IntVar(value=saved_cat)
            cat_vars[plan] = catv
            rcat = tk.Frame(frame, bg=C_WHITE)
            rcat.grid(row=gr, column=0, columnspan=4, sticky="w", padx=(12, 0), pady=(4, 2))
            tk.Label(rcat, text="Plan/Category Row:", bg=C_WHITE,
                     font=("Segoe UI", 9)).pack(side="left")
            cats = tk.Spinbox(rcat, from_=1, to=50, width=4, textvariable=catv,
                              font=("Segoe UI", 9),
                              command=lambda p=plan, v=catv: _save_row(p, v, "category_rows"))
            cats.pack(side="left", padx=(4, 0))
            cats.bind("<FocusOut>", lambda e, p=plan, v=catv: _save_row(p, v, "category_rows"))
            cats.bind("<Return>",   lambda e, p=plan, v=catv: _save_row(p, v, "category_rows"))
            gr += 1

        # Separator
        tk.Frame(frame, bg=C_SEP, height=1).grid(
            row=gr, column=0, columnspan=4, sticky="ew", pady=(8, 0))
        gr += 1

    return frame, t_vars, sp_vars, hr_vars, cat_vars


