def _dsnp_worker():
    refs       = dsnp_refs
    plan       = refs['plan_var'].get()
    data_path  = refs['data_path_holder'][0]
    tmpl_path  = settings.get("templates",  {}).get(plan, "").strip()
    header_row = dsnp_hr_vars[plan].get()

    if not tmpl_path or not os.path.exists(tmpl_path):
        def err():
            refs['gen_btn'].config(state="normal"); refs['status_var'].set("Error.")
            messagebox.showerror("Missing Template",
                f"No template configured for {plan}.\nGo to Settings → DSNP Setting.")
        root.after(0, err); return
    if not data_path or not os.path.exists(data_path):
        def err():
            refs['gen_btn'].config(state="normal"); refs['status_var'].set("Error.")
            messagebox.showerror("Missing Data File", "Please select a 3C QES data file.")
        root.after(0, err); return

    path_2c  = refs['data_3c2c_holder'][0]
    path_2c  = path_2c if (path_2c and os.path.exists(path_2c)) else None
    wi_paths = [s["holder"][0] for s in refs['whatif_scenarios']
                if s["holder"][0] and os.path.exists(s["holder"][0])]
    p3c      = refs['prev_3c_holder'][0]
    p3c      = p3c if (p3c and os.path.exists(p3c)) else None
    p3c2c    = refs['prev_3c2c_holder'][0]
    p3c2c    = p3c2c if (p3c2c and os.path.exists(p3c2c)) else None
    pwi      = [s["holder"][0] for s in refs['prev_whatif_scenarios']
                if s["holder"][0] and os.path.exists(s["holder"][0])]

    plan_sn   = settings.get("sheet_names", {}).get(plan, _DEFAULT_SHEET_NAMES)
    save_path = settings.get("save_paths",  {}).get(plan, "").strip() or None

    try:
        out_path, matched = run_populate(
            tmpl_path, data_path, header_row,
            path_2c, wi_paths or None,
            p3c, p3c2c, pwi or None,
            plan=plan, sheet_names=plan_sn, save_path=save_path)
        def done():
            refs['gen_btn'].config(state="normal")
            refs['status_var'].set(f"Done!  {os.path.basename(out_path)}")
            messagebox.showinfo("Report Generated",
                f"Saved to:\n{out_path}\n\n{matched} cells populated.")
            if sys.platform == "win32": os.startfile(out_path)
            else: os.system(f'open "{out_path}"')
        root.after(0, done)
    except Exception as exc:
        msg = str(exc)
        def on_err():
            refs['gen_btn'].config(state="normal"); refs['status_var'].set("Error.")
            messagebox.showerror("Error", msg)
        root.after(0, on_err)


