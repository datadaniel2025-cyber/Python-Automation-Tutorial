def _write_adequacy_sheet(wb, sheet_name, title, lookup_curr, lookup_prev,
                           curr_thursday, prev_thursday, position=0,
                           county_active=None):
    data_rows = []
    for (specialty, county), curr_raw in lookup_curr.items():
        prev_raw = lookup_prev.get((specialty, county))
        if prev_raw is None:
            continue
        curr_pct = float(curr_raw)
        prev_pct = float(prev_raw)
        diff     = round(curr_pct - prev_pct, 6)
        if diff == 0:
            continue
        data_rows.append((county, specialty, prev_pct, curr_pct, diff))
    if not data_rows:
        return False
    data_rows.sort(key=lambda x: (x[0], x[1]))

    if sheet_name in wb.sheetnames:
        del wb[sheet_name]
    ws = wb.create_sheet(sheet_name, position)

    friday = curr_thursday + timedelta(days=1)

    navy_fill  = PatternFill(start_color="1F3864", end_color="1F3864", fill_type="solid")
    blue_fill  = PatternFill(start_color="2E5DA6", end_color="2E5DA6", fill_type="solid")
    alt_fill   = PatternFill(start_color="EDF2FF", end_color="EDF2FF", fill_type="solid")
    green_fill = PatternFill(start_color="70AD47", end_color="70AD47", fill_type="solid")
    red_fill   = PatternFill(start_color="C00000", end_color="C00000", fill_type="solid")

    title_font = Font(name="Segoe UI", bold=True,  color="FFFFFF", size=13)
    sub_font   = Font(name="Segoe UI", italic=True, color="FFFFFF", size=10)
    hdr_font   = Font(name="Segoe UI", bold=True,  color="FFFFFF", size=10)
    body_font  = Font(name="Segoe UI", size=10)
    white_bold = Font(name="Segoe UI", bold=True,  color="FFFFFF", size=10)
    up_font    = Font(name="Segoe UI", size=10, color="375623")
    down_font  = Font(name="Segoe UI", size=10, color="C00000")

    _s  = Side(style="thin", color="9BB7D4")
    brd = Border(left=_s, right=_s, top=_s, bottom=_s)
    mid = Alignment(horizontal="center", vertical="center")
    lft = Alignment(horizontal="left",   vertical="center")

    LAST = 8
    ws.merge_cells(start_row=2, start_column=2, end_row=2, end_column=LAST)
    c = ws.cell(row=2, column=2)
    c.value = title; c.font = title_font; c.fill = navy_fill; c.alignment = mid

    ws.merge_cells(start_row=3, start_column=2, end_row=3, end_column=LAST)
    c = ws.cell(row=3, column=2)
    c.value = f"Comparison as of {friday.strftime('%m/%d/%Y')}"
    c.font = sub_font; c.fill = blue_fill; c.alignment = mid

    for ci, h in enumerate(["County Name", "Specialty", "Active Servicing Counties",
                             prev_thursday.strftime('%m/%d/%Y'),
                             curr_thursday.strftime('%m/%d/%Y'),
                             "Difference", "Status"], start=2):
        c = ws.cell(row=4, column=ci)
        c.value = h; c.font = hdr_font; c.fill = blue_fill
        c.border = brd; c.alignment = mid

    for ri, (county, specialty, prev_pct, curr_pct, diff) in enumerate(data_rows, start=5):
        rfill = alt_fill if ri % 2 == 0 else None

        def _w(col, val, al=lft, fmt=None, _ri=ri, _rf=rfill):
            c = ws.cell(row=_ri, column=col)
            c.value = val; c.font = body_font; c.border = brd; c.alignment = al
            if _rf: c.fill = _rf
            if fmt: c.number_format = fmt

        _w(2, county)
        _w(3, specialty)
        _w(4, (county_active or {}).get(county), al=mid)
        _w(5, round(prev_pct * 0.01, 4), al=mid, fmt="0.00%")
        _w(6, round(curr_pct * 0.01, 4), al=mid, fmt="0.00%")

        if diff > 0:
            diff_str = f"▲ {diff:.2f}%"
            diff_fnt = up_font
        else:
            diff_str = f"▼ {diff:.2f}%"
            diff_fnt = down_font
        dc = ws.cell(row=ri, column=7)
        dc.value = diff_str; dc.font = diff_fnt; dc.border = brd; dc.alignment = mid
        if rfill: dc.fill = rfill

        sc = ws.cell(row=ri, column=8)
        sc.border = brd; sc.alignment = mid
        if prev_pct < 90 and curr_pct >= 90:
            sc.value = "Gap Closed";     sc.fill = green_fill; sc.font = white_bold
        elif prev_pct >= 90 and curr_pct < 90:
            sc.value = "New Gap Opened"; sc.fill = red_fill;   sc.font = white_bold
        elif prev_pct < 90 and curr_pct < 90:
            sc.value = "Existing Gap";          sc.font = body_font
            if rfill: sc.fill = rfill
        else:
            sc.value = "ADEQUATE - NO IMPACT";  sc.font = body_font
            if rfill: sc.fill = rfill

    for ci, w in zip(range(2, 9), [22, 32, 24, 14, 14, 12, 16]):
        ws.column_dimensions[ws.cell(row=4, column=ci).column_letter].width = w
    ws.row_dimensions[2].height = 30
    ws.row_dimensions[3].height = 20
    ws.row_dimensions[4].height = 18
    return True


# ── DSNP lookup / populate ────────────────────────────────────────────────
def _build_lookup(data_path):
    ds_wb = openpyxl.load_workbook(data_path, data_only=True)
    ds_ws = ds_wb.active

    col_specialty = col_county = col_pct = None
    for c in range(1, ds_ws.max_column + 1):
        raw = ds_ws.cell(1, c).value
        if raw is None:
            continue
        key = str(raw).strip().lower()
        if key == "specialty group name":
            col_specialty = c
        elif key == "county name":
            col_county = c
        elif key == "% members with access":
            col_pct = c

    missing = [name for name, col in [
        ("Specialty Group Name", col_specialty),
        ("County Name",          col_county),
        ("% Members With Access", col_pct),
    ] if col is None]
    if missing:
        raise ValueError(
            f"{os.path.basename(data_path)}: required column(s) not found in row 1: "
            + ", ".join(missing))

    lookup = {}
    for r in range(2, ds_ws.max_row + 1):
        specialty = ds_ws.cell(r, col_specialty).value
        county    = ds_ws.cell(r, col_county).value
        pct       = ds_ws.cell(r, col_pct).value
        if specialty is None or county is None:
            continue
        if str(specialty).strip().lower() == "copyright":
            continue
        lookup[(str(specialty).strip(), str(county).strip())] = pct
    return lookup


def _populate_sheets(out_wb, sheet_names, lookup, header_row):
    COUNTY_COL = 1
    SPEC_START = 4
    matched = 0
    for sheet_name in sheet_names:
        if sheet_name not in out_wb.sheetnames:
            continue
        ws = out_wb[sheet_name]
        spec_cols = {}
        for col in range(SPEC_START, ws.max_column + 1):
            val = ws.cell(header_row, col).value
            if val:
                spec_cols[col] = str(val).strip()
        for row in range(header_row + 1, ws.max_row + 1):
            county_val = ws.cell(row, COUNTY_COL).value
            if county_val is None:
                continue
            county = str(county_val).strip()
            for col, specialty in spec_cols.items():
                if (specialty, county) in lookup:
                    raw = lookup[(specialty, county)]
                    ws.cell(row, col).value = round(float(raw) * 0.01, 4) if raw is not None else None
                    matched += 1
    return matched


def _populate_variance_sheets(out_wb, sheet_names, lookup_curr, lookup_prev, header_row):
    COUNTY_COL = 1
    SPEC_START = 4
    matched = 0
    for sheet_name in sheet_names:
        if sheet_name not in out_wb.sheetnames:
            continue
        ws = out_wb[sheet_name]
        spec_cols = {}
        for col in range(SPEC_START, ws.max_column + 1):
            val = ws.cell(header_row, col).value
            if val:
                spec_cols[col] = str(val).strip()
        for row in range(header_row + 1, ws.max_row + 1):
            county_val = ws.cell(row, COUNTY_COL).value
            if county_val is None:
                continue
            county = str(county_val).strip()
            for col, specialty in spec_cols.items():
                key = (specialty, county)
                curr = lookup_curr.get(key)
                prev = lookup_prev.get(key)
                if curr is not None and prev is not None:
                    ws.cell(row, col).value = round(float(curr) * 0.01 - float(prev) * 0.01, 4)
                    matched += 1
    return matched


def run_populate(template_path, data_path_3c, header_row=4,
                 data_path_3c2c=None, whatif_paths=None,
                 prev_3c_path=None, prev_3c2c_path=None, prev_whatif_paths=None,
                 plan="", sheet_names=None, save_path=None):
    today         = date.today()
    thursday      = today + timedelta(days=3 - today.weekday()) - timedelta(weeks=1)
    prev_thursday = thursday - timedelta(weeks=2)
    friday        = thursday + timedelta(days=1)
    plan_slug     = plan.replace(" ", "_") if plan else "DSNP"
    out_name      = f"{plan_slug}_Adequacy_{friday.strftime('%m%d%Y')}.xlsx"
    save_dir      = save_path if (save_path and os.path.isdir(save_path)) else os.path.dirname(data_path_3c)
    out_path      = os.path.join(save_dir, out_name)

    shutil.copy2(template_path, out_path)
    lookup_3c   = _build_lookup(data_path_3c)
    lookup_3c2c = _build_lookup(data_path_3c2c) if data_path_3c2c else None
    out_wb = openpyxl.load_workbook(out_path)
    sn = sheet_names or _DEFAULT_SHEET_NAMES

    date_text = f"   DATA AS OF {thursday.strftime('%m/%d/%Y')}"
    _stamp = list(sn["3c"])
    if data_path_3c2c:   _stamp += sn["3c2c"]
    if whatif_paths:     _stamp += sn["whatif"]
    if prev_3c_path:     _stamp += sn["3c_var"]
    if prev_3c2c_path and data_path_3c2c: _stamp += sn["3c2c_var"]
    if prev_whatif_paths and whatif_paths: _stamp += sn["whatif_var"]
    for ws_name in _stamp:
        if ws_name in out_wb.sheetnames:
            out_wb[ws_name]["A2"].value = date_text

    total_matched  = _populate_sheets(out_wb, sn["3c"], lookup_3c, header_row)
    if lookup_3c2c is not None:
        total_matched += _populate_sheets(out_wb, sn["3c2c"], lookup_3c2c, header_row)

    wi_lookups = []
    for wi_path in (whatif_paths or []):
        lk = _build_lookup(wi_path)
        wi_lookups.append(lk)
        total_matched += _populate_sheets(out_wb, sn["whatif"], lk, header_row)

    lookup_prev_3c   = _build_lookup(prev_3c_path)   if prev_3c_path   else None
    lookup_prev_3c2c = _build_lookup(prev_3c2c_path) if prev_3c2c_path else None

    if lookup_prev_3c:
        total_matched += _populate_variance_sheets(out_wb, sn["3c_var"], lookup_3c, lookup_prev_3c, header_row)
    if lookup_prev_3c2c and lookup_3c2c is not None:
        total_matched += _populate_variance_sheets(out_wb, sn["3c2c_var"], lookup_3c2c, lookup_prev_3c2c, header_row)

    prev_wi_lookups = []
    for i, prev_wi in enumerate(prev_whatif_paths or [], start=1):
        if i > len(wi_lookups):
            break
        lk_prev = _build_lookup(prev_wi)
        prev_wi_lookups.append(lk_prev)
        total_matched += _populate_variance_sheets(out_wb, sn["whatif_var"], wi_lookups[i-1], lk_prev, header_row)

    county_active = {}
    prac_3c_name = sn["3c"][0]
    if prac_3c_name in out_wb.sheetnames:
        prac_ws = out_wb[prac_3c_name]
        for row in range(header_row + 1, prac_ws.max_row + 1):
            county_val = prac_ws.cell(row, 1).value
            active_val = prac_ws.cell(row, 4).value
            if county_val:
                county_active[str(county_val).strip()] = active_val

    _pos = [0]
    if lookup_prev_3c:
        if _write_adequacy_sheet(out_wb, "Adequacy Change 3C",
                f"{plan} 3C Scenario Comparison Result",
                lookup_3c, lookup_prev_3c, thursday, prev_thursday,
                position=_pos[0], county_active=county_active):
            _pos[0] += 1
    if lookup_3c2c is not None and lookup_prev_3c2c:
        if _write_adequacy_sheet(out_wb, "Adequacy Change 3C2C",
                f"{plan} 3C2C Scenario Comparison Result",
                lookup_3c2c, lookup_prev_3c2c, thursday, prev_thursday,
                position=_pos[0], county_active=county_active):
            _pos[0] += 1
    for i, lk_prev in enumerate(prev_wi_lookups, start=1):
        if _write_adequacy_sheet(out_wb, f"Adequacy Change What-If {i}",
                f"{plan} What-If Scenario {i} Comparison Result",
                wi_lookups[i-1], lk_prev, thursday, prev_thursday,
                position=_pos[0], county_active=county_active):
            _pos[0] += 1

    sheets_to_drop = []
    if lookup_3c2c is None:
        sheets_to_drop += sn["3c2c"] + sn["3c2c_var"]
    if not wi_lookups:
        sheets_to_drop += sn["whatif"] + sn["whatif_var"]
    if lookup_prev_3c is None:
        sheets_to_drop += sn["3c_var"]
    if lookup_3c2c is None or lookup_prev_3c2c is None:
        for s in sn["3c2c_var"]:
            if s not in sheets_to_drop: sheets_to_drop.append(s)
    if not wi_lookups or not prev_wi_lookups:
        for s in sn["whatif_var"]:
            if s not in sheets_to_drop: sheets_to_drop.append(s)
    for sname in sheets_to_drop:
        if sname in out_wb.sheetnames:
            del out_wb[sname]

    out_wb.save(out_path)
    return out_path, total_matched


def _write_qhp_adequacy_sheet(wb, sheet_name, title, lookup_curr, lookup_prev,
                               curr_thursday, prev_thursday, position=0):
    """Same styled Adequacy Change sheet as _write_adequacy_sheet but for QHP.
    Keys in lookups are (prefix, specialty, county); Specialty column shows 'prefix - specialty'."""
    data_rows = []
    for (prefix, specialty, county), curr_raw in lookup_curr.items():
        prev_raw = lookup_prev.get((prefix, specialty, county))
        if prev_raw is None:
            continue
        try:
            curr_pct = float(curr_raw)
            prev_pct = float(prev_raw)
        except (TypeError, ValueError):
            continue
        diff = round(curr_pct - prev_pct, 6)
        if diff == 0:
            continue
        display_specialty = f"{prefix} - {specialty}"
        data_rows.append((county, display_specialty, prev_pct, curr_pct, diff))
    if not data_rows:
        return False
    data_rows.sort(key=lambda x: (x[0], x[1]))

    if sheet_name in wb.sheetnames:
        del wb[sheet_name]
    ws = wb.create_sheet(sheet_name, position)

    friday = curr_thursday + timedelta(days=1)

    navy_fill  = PatternFill(start_color="1F3864", end_color="1F3864", fill_type="solid")
    blue_fill  = PatternFill(start_color="2E5DA6", end_color="2E5DA6", fill_type="solid")
    alt_fill   = PatternFill(start_color="EDF2FF", end_color="EDF2FF", fill_type="solid")
    green_fill = PatternFill(start_color="70AD47", end_color="70AD47", fill_type="solid")
    red_fill   = PatternFill(start_color="C00000", end_color="C00000", fill_type="solid")

    title_font = Font(name="Segoe UI", bold=True,  color="FFFFFF", size=13)
    sub_font   = Font(name="Segoe UI", italic=True, color="FFFFFF", size=10)
    hdr_font   = Font(name="Segoe UI", bold=True,  color="FFFFFF", size=10)
    body_font  = Font(name="Segoe UI", size=10)
    white_bold = Font(name="Segoe UI", bold=True,  color="FFFFFF", size=10)
    up_font    = Font(name="Segoe UI", size=10, color="375623")
    down_font  = Font(name="Segoe UI", size=10, color="C00000")

    _s  = Side(style="thin", color="9BB7D4")
    brd = Border(left=_s, right=_s, top=_s, bottom=_s)
    mid = Alignment(horizontal="center", vertical="center")
    lft = Alignment(horizontal="left",   vertical="center")

    LAST = 7
    ws.merge_cells(start_row=2, start_column=2, end_row=2, end_column=LAST)
    c = ws.cell(row=2, column=2)
    c.value = title; c.font = title_font; c.fill = navy_fill; c.alignment = mid

    ws.merge_cells(start_row=3, start_column=2, end_row=3, end_column=LAST)
    c = ws.cell(row=3, column=2)
    c.value = f"Comparison as of {friday.strftime('%m/%d/%Y')}"
    c.font = sub_font; c.fill = blue_fill; c.alignment = mid

    for ci, h in enumerate(["County Name", "Plan - Specialty",
                             prev_thursday.strftime('%m/%d/%Y'),
                             curr_thursday.strftime('%m/%d/%Y'),
                             "Difference", "Status"], start=2):
        c = ws.cell(row=4, column=ci)
        c.value = h; c.font = hdr_font; c.fill = blue_fill
        c.border = brd; c.alignment = mid

    for ri, (county, display_specialty, prev_pct, curr_pct, diff) in enumerate(data_rows, start=5):
        rfill = alt_fill if ri % 2 == 0 else None

        def _w(col, val, al=lft, fmt=None, _ri=ri, _rf=rfill):
            c = ws.cell(row=_ri, column=col)
            c.value = val; c.font = body_font; c.border = brd; c.alignment = al
            if _rf: c.fill = _rf
            if fmt: c.number_format = fmt

        _w(2, county)
        _w(3, display_specialty)
        _w(4, round(prev_pct * 0.01, 4), al=mid, fmt="0.00%")
        _w(5, round(curr_pct * 0.01, 4), al=mid, fmt="0.00%")

        if diff > 0:
            diff_str = f"▲ {diff:.2f}%"
            diff_fnt = up_font
        else:
            diff_str = f"▼ {diff:.2f}%"
            diff_fnt = down_font
        dc = ws.cell(row=ri, column=6)
        dc.value = diff_str; dc.font = diff_fnt; dc.border = brd; dc.alignment = mid
        if rfill: dc.fill = rfill

        sc = ws.cell(row=ri, column=7)
        sc.border = brd; sc.alignment = mid
        if prev_pct < 90 and curr_pct >= 90:
            sc.value = "Gap Closed";     sc.fill = green_fill; sc.font = white_bold
        elif prev_pct >= 90 and curr_pct < 90:
            sc.value = "New Gap Opened"; sc.fill = red_fill;   sc.font = white_bold
        elif prev_pct < 90 and curr_pct < 90:
            sc.value = "Existing Gap";          sc.font = body_font
            if rfill: sc.fill = rfill
        else:
            sc.value = "ADEQUATE - NO IMPACT";  sc.font = body_font
            if rfill: sc.fill = rfill

    for ci, w in zip(range(2, 8), [22, 36, 14, 14, 12, 20]):
        ws.column_dimensions[ws.cell(row=4, column=ci).column_letter].width = w
    ws.row_dimensions[2].height = 30
    ws.row_dimensions[3].height = 20
    ws.row_dimensions[4].height = 18
    return True


# ── QHP lookup / populate ─────────────────────────────────────────────────
def _build_qhp_lookup(data_path):
    """Returns {(prefix, specialty, county): pct} where prefix is extracted
    from the 'Results For' column (e.g. 'QHP - 5/6/2026' → 'QHP')."""
    ds_wb = openpyxl.load_workbook(data_path, data_only=True)
    ds_ws = ds_wb.active

    col_results = col_specialty = col_county = col_pct = None
    for c in range(1, ds_ws.max_column + 1):
        raw = ds_ws.cell(1, c).value
        if raw is None:
            continue
        key = str(raw).strip().lower()
        if key == "results for":
            col_results = c
        elif key == "specialty group name":
            col_specialty = c
        elif key == "county name":
            col_county = c
        elif key == "% members with access":
            col_pct = c

    missing = [name for name, col in [
        ("Results For",           col_results),
        ("Specialty Group Name",  col_specialty),
        ("County Name",           col_county),
        ("% Members With Access", col_pct),
    ] if col is None]
    if missing:
        raise ValueError(
            f"{os.path.basename(data_path)}: required column(s) not found in row 1: "
            + ", ".join(missing))

    lookup = {}
    for r in range(2, ds_ws.max_row + 1):
        results_for = ds_ws.cell(r, col_results).value
        specialty   = ds_ws.cell(r, col_specialty).value
        county      = ds_ws.cell(r, col_county).value
        pct         = ds_ws.cell(r, col_pct).value
        if results_for is None or specialty is None or county is None:
            continue
        rf_str = str(results_for).strip()
        if rf_str.lower() == "copyright":
            continue
        prefix = rf_str.split(" - ")[0].strip() if " - " in rf_str else rf_str
        lookup[(prefix, str(specialty).strip(), str(county).strip())] = pct
    return lookup


def _populate_qhp_sheets(out_wb, sheet_names, lookup, header_row, category_row):
    """Populates QHP template sheets.
    header_row    = row containing specialty names (e.g. row 6)
    category_row  = row containing QHP/plan prefix values (e.g. row 5)
    """
    COUNTY_COL = 1
    SPEC_START = 4
    matched = 0
    for sheet_name in sheet_names:
        if sheet_name not in out_wb.sheetnames:
            continue
        ws = out_wb[sheet_name]
        spec_cols = {}
        for col in range(SPEC_START, ws.max_column + 1):
            spec_val = ws.cell(header_row, col).value
            cat_val  = ws.cell(category_row, col).value
            if spec_val and cat_val:
                spec_cols[col] = (str(spec_val).strip(), str(cat_val).strip())
        for row in range(header_row + 1, ws.max_row + 1):
            county_val = ws.cell(row, COUNTY_COL).value
            if county_val is None:
                continue
            county = str(county_val).strip()
            for col, (specialty, prefix) in spec_cols.items():
                key = (prefix, specialty, county)
                if key in lookup:
                    raw = lookup[key]
                    if raw is None:
                        pass
                    elif str(raw).strip() == "---":
                        ws.cell(row, col).value = "N/A"
                    else:
                        try:
                            ws.cell(row, col).value = round(float(raw) * 0.01, 4)
                        except (ValueError, TypeError):
                            ws.cell(row, col).value = "N/A"
                    matched += 1
    return matched


def _populate_qhp_variance_sheets(out_wb, sheet_names, lookup_curr, lookup_prev,
                                   header_row, category_row):
    COUNTY_COL = 1
    SPEC_START = 4
    matched = 0
    for sheet_name in sheet_names:
        if sheet_name not in out_wb.sheetnames:
            continue
        ws = out_wb[sheet_name]
        spec_cols = {}
        for col in range(SPEC_START, ws.max_column + 1):
            spec_val = ws.cell(header_row, col).value
            cat_val  = ws.cell(category_row, col).value
            if spec_val and cat_val:
                spec_cols[col] = (str(spec_val).strip(), str(cat_val).strip())
        for row in range(header_row + 1, ws.max_row + 1):
            county_val = ws.cell(row, COUNTY_COL).value
            if county_val is None:
                continue
            county = str(county_val).strip()
            for col, (specialty, prefix) in spec_cols.items():
                key = (prefix, specialty, county)
                curr = lookup_curr.get(key)
                prev = lookup_prev.get(key)
                if curr is not None and prev is not None:
                    try:
                        ws.cell(row, col).value = round(
                            float(curr) * 0.01 - float(prev) * 0.01, 4)
                        matched += 1
                    except (ValueError, TypeError):
                        pass
    return matched


def run_populate_qhp(template_path, data_path_3c, header_row=6, category_row=5,
                     data_path_3c2c=None, whatif_paths=None,
                     prev_3c_path=None, prev_3c2c_path=None, prev_whatif_paths=None,
                     plan="", sheet_names=None, save_path=None):
    today         = date.today()
    thursday      = today + timedelta(days=3 - today.weekday()) - timedelta(weeks=1)
    prev_thursday = thursday - timedelta(weeks=2)
    friday        = thursday + timedelta(days=1)
    plan_slug     = plan.replace(" ", "_") if plan else "QHP"
    out_name      = f"{plan_slug}_Adequacy_{friday.strftime('%m%d%Y')}.xlsx"
    save_dir      = save_path if (save_path and os.path.isdir(save_path)) else os.path.dirname(data_path_3c)
    out_path      = os.path.join(save_dir, out_name)

    shutil.copy2(template_path, out_path)
    lookup_3c   = _build_qhp_lookup(data_path_3c)
    lookup_3c2c = _build_qhp_lookup(data_path_3c2c) if data_path_3c2c else None
    out_wb = openpyxl.load_workbook(out_path)
    sn = sheet_names or _DEFAULT_SHEET_NAMES

    date_text = f"   DATA AS OF {thursday.strftime('%m/%d/%Y')}"
    _stamp = list(sn["3c"])
    if data_path_3c2c:   _stamp += sn["3c2c"]
    if whatif_paths:     _stamp += sn["whatif"]
    if prev_3c_path:     _stamp += sn["3c_var"]
    if prev_3c2c_path and data_path_3c2c: _stamp += sn["3c2c_var"]
    if prev_whatif_paths and whatif_paths: _stamp += sn["whatif_var"]
    for ws_name in _stamp:
        if ws_name in out_wb.sheetnames:
            out_wb[ws_name]["A2"].value = date_text

    total_matched  = _populate_qhp_sheets(out_wb, sn["3c"], lookup_3c, header_row, category_row)
    if lookup_3c2c is not None:
        total_matched += _populate_qhp_sheets(out_wb, sn["3c2c"], lookup_3c2c, header_row, category_row)

    wi_lookups = []
    for wi_path in (whatif_paths or []):
        lk = _build_qhp_lookup(wi_path)
        wi_lookups.append(lk)
        total_matched += _populate_qhp_sheets(out_wb, sn["whatif"], lk, header_row, category_row)

    lookup_prev_3c   = _build_qhp_lookup(prev_3c_path)   if prev_3c_path   else None
    lookup_prev_3c2c = _build_qhp_lookup(prev_3c2c_path) if prev_3c2c_path else None

    if lookup_prev_3c:
        total_matched += _populate_qhp_variance_sheets(
            out_wb, sn["3c_var"], lookup_3c, lookup_prev_3c, header_row, category_row)
    if lookup_prev_3c2c and lookup_3c2c is not None:
        total_matched += _populate_qhp_variance_sheets(
            out_wb, sn["3c2c_var"], lookup_3c2c, lookup_prev_3c2c, header_row, category_row)

    prev_wi_lookups = []
    for i, prev_wi in enumerate(prev_whatif_paths or [], start=1):
        if i > len(wi_lookups):
            break
        lk_prev = _build_qhp_lookup(prev_wi)
        prev_wi_lookups.append(lk_prev)
        total_matched += _populate_qhp_variance_sheets(
            out_wb, sn["whatif_var"], wi_lookups[i-1], lk_prev, header_row, category_row)

    _pos = [0]
    if lookup_prev_3c:
        if _write_qhp_adequacy_sheet(out_wb, "Adequacy Change 3C",
                f"{plan} 3C Scenario Comparison Result",
                lookup_3c, lookup_prev_3c, thursday, prev_thursday,
                position=_pos[0]):
            _pos[0] += 1
    if lookup_3c2c is not None and lookup_prev_3c2c:
        if _write_qhp_adequacy_sheet(out_wb, "Adequacy Change 3C2C",
                f"{plan} 3C2C Scenario Comparison Result",
                lookup_3c2c, lookup_prev_3c2c, thursday, prev_thursday,
                position=_pos[0]):
            _pos[0] += 1
    for i, lk_prev in enumerate(prev_wi_lookups, start=1):
        if _write_qhp_adequacy_sheet(out_wb, f"Adequacy Change What-If {i}",
                f"{plan} What-If Scenario {i} Comparison Result",
                wi_lookups[i-1], lk_prev, thursday, prev_thursday,
                position=_pos[0]):
            _pos[0] += 1

    sheets_to_drop = []
    if lookup_3c2c is None:
        sheets_to_drop += sn["3c2c"] + sn["3c2c_var"]
    if not wi_lookups:
        sheets_to_drop += sn["whatif"] + sn["whatif_var"]
    if lookup_prev_3c is None:
        sheets_to_drop += sn["3c_var"]
    if lookup_3c2c is None or lookup_prev_3c2c is None:
        for s in sn["3c2c_var"]:
            if s not in sheets_to_drop: sheets_to_drop.append(s)
    if not wi_lookups or not prev_wi_lookups:
        for s in sn["whatif_var"]:
            if s not in sheets_to_drop: sheets_to_drop.append(s)
    for sname in sheets_to_drop:
        if sname in out_wb.sheetnames:
            del out_wb[sname]

    out_wb.save(out_path)
    return out_path, total_matched


