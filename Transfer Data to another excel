import tkinter as tk
from tkinter import filedialog, messagebox
import pandas as pd


def select_source_file():
    file_path = filedialog.askopenfilename(
        title="Select Source Excel File",
        filetypes=[("Excel Files", "*.xlsx *.xls")]
    )

    if file_path:
        source_file_entry.delete(0, tk.END)
        source_file_entry.insert(0, file_path)


def select_target_file():
    file_path = filedialog.askopenfilename(
        title="Select Target Excel File",
        filetypes=[("Excel Files", "*.xlsx")]
    )

    if file_path:
        target_file_entry.delete(0, tk.END)
        target_file_entry.insert(0, file_path)


def transfer_data():
    source_file = source_file_entry.get()
    target_file = target_file_entry.get()

    if not source_file:
        messagebox.showerror("Error", "Please select a source Excel file.")
        return

    if not target_file:
        messagebox.showerror("Error", "Please select a target Excel file.")
        return

    try:
        # Read data from source Excel
        source_data = pd.read_excel(source_file)

        # Read existing target data
        target_data = pd.read_excel(target_file)

        # Append source data to target data
        combined_data = pd.concat([target_data, source_data], ignore_index=True)

        # Save combined data back to target Excel
        combined_data.to_excel(target_file, index=False)

        messagebox.showinfo("Success", "Data transferred successfully!")

    except Exception as e:
        messagebox.showerror("Error", f"Something went wrong:\n{e}")


# Create main window
root = tk.Tk()
root.title("Simple Excel Data Transfer Tool")
root.geometry("600x220")

# Source file row
tk.Label(root, text="Source Excel File:").pack(pady=5)
source_file_entry = tk.Entry(root, width=70)
source_file_entry.pack()

tk.Button(
    root,
    text="Browse Source File",
    command=select_source_file
).pack(pady=5)

# Target file row
tk.Label(root, text="Target Excel File:").pack(pady=5)
target_file_entry = tk.Entry(root, width=70)
target_file_entry.pack()

tk.Button(
    root,
    text="Browse Target File",
    command=select_target_file
).pack(pady=5)

# Transfer button
tk.Button(
    root,
    text="Transfer Data",
    command=transfer_data,
    width=25
).pack(pady=15)

# Start app
root.mainloop()
