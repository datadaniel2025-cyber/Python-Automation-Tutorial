class ToolFrame(ttk.Frame):
    def __init__(self, app: App, mode: str):
        super().__init__(app, padding=24)
        self.app = app
        self.mode = mode
        self.config_data = app.config_data

        if mode == "access_detail":
            self.required_columns = REQUIRED_COLUMNS_ACCESS_DETAIL
