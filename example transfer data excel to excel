    # ── UI build ──────────────────────────────────────────────────────

    def _build_ui(self):
        outer = self

        # Back button
        ttk.Button(outer, text="← Back", command=self.app._show_landing,
                   width=10).grid(row=0, column=0, sticky=tk.W, pady=(0, 6))

        ttk.Label(outer, text=self.title_text,
                  font=("Segoe UI", 15, "bold")).grid(
            row=1, column=0, columnspan=3, pady=(0, 22))

        lbl_kw = dict(font=("Segoe UI", 10))
        combo_w = 28

        # State
        ttk.Label(outer, text="State *", **lbl_kw).grid(
            row=2, column=0, sticky=tk.W, pady=6)
        self.state_var = tk.StringVar()
        self.state_cb = ttk.Combobox(outer, textvariable=self.state_var,
                                     values=STATES, state="readonly", width=combo_w)
        self.state_cb.grid(row=2, column=1, sticky=tk.W, padx=(12, 0), pady=6)
        self.state_cb.bind("<<ComboboxSelected>>", self._on_dropdown_change)

        # LOB
        ttk.Label(outer, text="LOB *", **lbl_kw).grid(
            row=3, column=0, sticky=tk.W, pady=6)
        self.lob_var = tk.StringVar()
        self.lob_cb = ttk.Combobox(outer, textvariable=self.lob_var,
                                   values=LOBS, state="readonly", width=combo_w)
        self.lob_cb.grid(row=3, column=1, sticky=tk.W, padx=(12, 0), pady=6)
        self.lob_cb.bind("<<ComboboxSelected>>", self._on_dropdown_change)

        # Scenario
        ttk.Label(outer, text="Scenario *", **lbl_kw).grid(
            row=4, column=0, sticky=tk.W, pady=6)
        self.scenario_var = tk.StringVar()
        self.scenario_cb = ttk.Combobox(outer, textvariable=self.scenario_var,
                                        values=SCENARIOS, state="readonly", width=combo_w)
        self.scenario_cb.grid(row=4, column=1, sticky=tk.W, padx=(12, 0), pady=6)
        self.scenario_cb.bind("<<ComboboxSelected>>", self._on_dropdown_change)

        ttk.Separator(outer, orient=tk.HORIZONTAL).grid(
            row=5, column=0, columnspan=3, sticky=tk.EW, pady=14)

        # File selection
        ttk.Label(outer, text="Input File *", **lbl_kw).grid(
            row=6, column=0, sticky=tk.W, pady=6)
        self.file_var = tk.StringVar()
        self.file_entry = ttk.Entry(outer, textvariable=self.file_var,
                                    width=combo_w + 2, state="disabled")
        self.file_entry.grid(row=6, column=1, sticky=tk.W, padx=(12, 0), pady=6)
        self.browse_btn = ttk.Button(outer, text="Browse File…",
                                     command=self._browse_file, state="disabled")
        self.browse_btn.grid(row=6, column=2, padx=(8, 0))

        # Action buttons
        btn_frame = ttk.Frame(outer)
        btn_frame.grid(row=7, column=0, columnspan=3, pady=(18, 0))
        self.process_btn = ttk.Button(btn_frame, text="Process File",
                                      command=self._process_file, state="disabled",
                                      width=18)
        self.process_btn.pack(side=tk.LEFT, padx=6)
        ttk.Button(btn_frame, text="Settings ⚙", command=self._open_settings,
                   width=14).pack(side=tk.LEFT, padx=6)

        # Status label
        self.status_var = tk.StringVar(value="Select all required fields to continue.")
        ttk.Label(outer, textvariable=self.status_var,
                  font=("Segoe UI", 9), foreground="#555").grid(
            row=8, column=0, columnspan=3, pady=(12, 0))

    # ── Dropdown change ────────────────────────────────────────────────

    def _on_dropdown_change(self, _=None):
        all_selected = bool(self.state_var.get() and
                            self.lob_var.get() and
                            self.scenario_var.get())
        if all_selected:
            self.browse_btn.config(state="normal")
            self.status_var.set("All fields selected. Browse for an input file.")
        else:
            self.browse_btn.config(state="disabled")
            self.file_var.set("")
            self.process_btn.config(state="disabled")
            self.status_var.set("Select all required fields to continue.")

    # ── Browse input file ──────────────────────────────────────────────

    def _browse_file(self):
        path = filedialog.askopenfilename(
            title="Select Input File",
            filetypes=[("Excel/CSV files", "*.xlsx *.xls *.csv"), ("All files", "*.*")],
        )
        if path:
            self.file_var.set(path)
            self.process_btn.config(state="normal")
            self.status_var.set(f"File selected: {os.path.basename(path)}")

    # ── Process ────────────────────────────────────────────────────────

    def _process_file(self):
        state = self.state_var.get()
        lob = self.lob_var.get()
        scenario = self.scenario_var.get()
        input_path = self.file_var.get()

        missing_sel = [name for name, val in
                       [("State", state), ("LOB", lob), ("Scenario", scenario),
                        ("Input File", input_path)] if not val]
        if missing_sel:
            messagebox.showerror("Validation Error",
                                 "The following required fields are missing:\n\n" +
                                 "\n".join(f"  • {m}" for m in missing_sel))
            return

        key = config_key(state, lob, scenario)
        template_path = self.config_data.get(key, "").strip()
        if not template_path:
            messagebox.showerror(
                "Configuration Error",
                f"No output template path is configured for:\n\n"
                f"  State    : {state}\n"
                f"  LOB      : {lob}\n"
                f"  Scenario : {scenario}\n\n"
                "Please set it in Settings ⚙ before processing.",
            )
            return

        try:
            if input_path.lower().endswith(".csv"):
                with open(input_path, newline="", encoding="utf-8-sig") as f:
                    input_rows = [tuple(r) for r in csv.reader(f)]
            else:
                wb_in = openpyxl.load_workbook(input_path)
                input_rows = list(wb_in.active.iter_rows(values_only=True))
        except Exception as exc:
            messagebox.showerror("File Error", f"Cannot open input file:\n{exc}")
            return

        if not input_rows:
            messagebox.showerror("File Error", "The selected input file is empty.")
            return

        input_headers = [str(h) if h is not None else "" for h in input_rows[0]]

        missing_cols = [col for col in self.required_columns if col not in input_headers]
        if missing_cols:
            messagebox.showerror(
                "Missing Required Columns",
                "The following required columns are missing from the input file:\n\n" +
                "\n".join(f"  • {c}" for c in missing_cols),
            )
            return

        data_rows = input_rows[1:]

        col_index = {name: idx for idx, name in enumerate(input_headers)}

        spec_filter = get_specialty_filter(self.config_data, state, lob)
        if spec_filter is not None:
            spec_idx = col_index.get("Specialty Group Name")
            if spec_idx is not None:
                before = len(data_rows)
                data_rows = [
                    r for r in data_rows
                    if (str(r[spec_idx]).strip().lower()
                        if spec_idx < len(r) and r[spec_idx] is not None else "")
                    in spec_filter
                ]
                filtered_out = before - len(data_rows)
            else:
                filtered_out = 0
        else:
            filtered_out = 0

        exp_counties = get_expansion_counties(self.config_data, state)
        county_idx = col_index.get("County Name")

        if os.path.exists(template_path):
            try:
                wb_out = openpyxl.load_workbook(template_path)
            except Exception as exc:
                messagebox.showerror("Template Error",
                                     f"Cannot open template file:\n{exc}")
                return
            ws_out = wb_out.active
        else:
            wb_out = openpyxl.Workbook()
            ws_out = wb_out.active

        protected_row = None
        for mr in ws_out.merged_cells.ranges:
            if protected_row is None or mr.min_row < protected_row:
                protected_row = mr.min_row

        output_headers = self.required_columns + ["State Name", "LOB", "Scenario",
                                                   "Expansion Counties"]
        output_rows = [output_headers]
        for row in data_rows:
            extracted = [
                row[col_index[col]] if col_index[col] < len(row) else None
                for col in self.required_columns
            ]
            county_name = ""
            if county_idx is not None and county_idx < len(row) and row[county_idx] is not None:
                county_name = str(row[county_idx]).strip()
            expansion_val = "Y" if county_name.lower() in exp_counties else ""
            output_rows.append(extracted + [state, lob, scenario, expansion_val])

        if protected_row is not None and protected_row > 1:
            ws_out.delete_rows(1, protected_row - 1)
            ws_out.insert_rows(1, len(output_rows))
        else:
            if ws_out.max_row:
                ws_out.delete_rows(1, ws_out.max_row)

        for r_idx, row_data in enumerate(output_rows, 1):
            for c_idx, val in enumerate(row_data, 1):
                ws_out.cell(row=r_idx, column=c_idx, value=val)

        try:
            os.makedirs(os.path.dirname(os.path.abspath(template_path)), exist_ok=True)
            wb_out.save(template_path)
        except Exception as exc:
            messagebox.showerror("Save Error", f"Failed to save output file:\n{exc}")
            return

        rows_written = len(data_rows)
        filter_note = (f"\n  Rows filtered: {filtered_out} (specialty filter active)"
                       if filtered_out else "")
        messagebox.showinfo(
            "Success",
            f"File processed and overwritten successfully.\n\n"
            f"  Rows written : {rows_written}{filter_note}\n"
            f"  Output file  : {os.path.basename(template_path)}",
        )
        self.status_var.set(f"Done — {rows_written} row(s) written to "
                            f"{os.path.basename(template_path)}.")

    # ── Settings ───────────────────────────────────────────────────────

    def _open_settings(self):
        SettingsWindow(self.app)


# ─────────────────────────── Settings Window ────────────────────────────────

class SettingsWindow(tk.Toplevel):
    def __init__(self, app: App):
        super().__init__(app)
        self.parent = app   # .parent used throughout for config_data access
        self.title("Settings")
        self.resizable(True, True)
        self.grab_set()
        self._build_ui()
        self._center()

    def _center(self):
        self.update_idletasks()
        w, h = self.winfo_width(), self.winfo_height()
        pw = self.parent.winfo_rootx() + self.parent.winfo_width() // 2
        ph = self.parent.winfo_rooty() + self.parent.winfo_height() // 2
        self.geometry(f"+{pw - w // 2}+{ph - h // 2}")

    def _build_ui(self):
        self.geometry("820x560")
        notebook = ttk.Notebook(self)
        notebook.pack(fill=tk.BOTH, expand=True, padx=10, pady=(10, 0))

        # Tab 1 – Output Paths
        paths_tab = ttk.Frame(notebook, padding=14)
        notebook.add(paths_tab, text="  Output Paths  ")
        self._build_paths_tab(paths_tab)

        # Tab 2 – Expansion Counties
        exp_tab = ttk.Frame(notebook, padding=14)
        notebook.add(exp_tab, text="  Expansion Counties  ")
        self._build_expansion_tab(exp_tab)

        # Tab 3 – Required Specialty Group Filter
        spec_tab = ttk.Frame(notebook, padding=14)
        notebook.add(spec_tab, text="  Required Specialty Group Filter  ")
        self._build_specialty_tab(spec_tab)

        ttk.Button(self, text="Close", command=self.destroy, width=10).pack(
            side=tk.RIGHT, padx=14, pady=8)

    # ══════════════════════════════════════════════════════════════════
    # Tab 1 – Output Paths
    # ══════════════════════════════════════════════════════════════════

    def _build_paths_tab(self, parent):
        lbl_kw = dict(font=("Segoe UI", 9))

        ttk.Label(parent, text="Select a combination to configure its output path:",
                  font=("Segoe UI", 10, "bold")).grid(
            row=0, column=0, columnspan=7, sticky=tk.W, pady=(0, 10))

        ttk.Label(parent, text="State:", **lbl_kw).grid(row=1, column=0, sticky=tk.W)
        self.s_state = tk.StringVar()
        s_state_cb = ttk.Combobox(parent, textvariable=self.s_state, values=STATES,
                                  state="readonly", width=18)
        s_state_cb.grid(row=1, column=1, padx=(4, 8))
        s_state_cb.bind("<<ComboboxSelected>>", self._load_path)

        ttk.Label(parent, text="LOB:", **lbl_kw).grid(row=1, column=2, sticky=tk.W)
        self.s_lob = tk.StringVar()
        s_lob_cb = ttk.Combobox(parent, textvariable=self.s_lob, values=LOBS,
                                state="readonly", width=12)
        s_lob_cb.grid(row=1, column=3, padx=(4, 8))
        s_lob_cb.bind("<<ComboboxSelected>>", self._load_path)

        ttk.Label(parent, text="Scenario:", **lbl_kw).grid(row=1, column=4, sticky=tk.W)
        self.s_scenario = tk.StringVar()
        s_scenario_cb = ttk.Combobox(parent, textvariable=self.s_scenario, values=SCENARIOS,
                                     state="readonly", width=10)
        s_scenario_cb.grid(row=1, column=5, padx=(4, 8))
        s_scenario_cb.bind("<<ComboboxSelected>>", self._load_path)

        ttk.Button(parent, text="Load", width=7,
                   command=self._load_path).grid(row=1, column=6)

        path_frame = ttk.Frame(parent)
        path_frame.grid(row=2, column=0, columnspan=7, sticky=tk.EW, pady=(10, 0))
        ttk.Label(path_frame, text="Output Path:", **lbl_kw).pack(side=tk.LEFT)
        self.path_var = tk.StringVar()
        ttk.Entry(path_frame, textvariable=self.path_var, width=52).pack(
            side=tk.LEFT, padx=(8, 6))
        ttk.Button(path_frame, text="Browse…",
                   command=self._browse_path).pack(side=tk.LEFT, padx=(0, 6))
        ttk.Button(path_frame, text="Save Path",
                   command=self._save_path).pack(side=tk.LEFT)

        ttk.Separator(parent, orient=tk.HORIZONTAL).grid(
            row=3, column=0, columnspan=7, sticky=tk.EW, pady=12)

        ttk.Label(parent, text="All configured paths:",
                  font=("Segoe UI", 10, "bold")).grid(
            row=4, column=0, columnspan=7, sticky=tk.W, pady=(0, 6))

        tree_frame = ttk.Frame(parent)
        tree_frame.grid(row=5, column=0, columnspan=7, sticky=tk.NSEW)
        parent.rowconfigure(5, weight=1)
        parent.columnconfigure(1, weight=1)

        cols = ("state", "lob", "scenario", "path")
        self.tree = ttk.Treeview(tree_frame, columns=cols, show="headings", height=9)
        self.tree.heading("state", text="State")
        self.tree.heading("lob", text="LOB")
        self.tree.heading("scenario", text="Scenario")
        self.tree.heading("path", text="Output Path")
        self.tree.column("state", width=130, anchor=tk.W)
        self.tree.column("lob", width=75, anchor=tk.CENTER)
        self.tree.column("scenario", width=75, anchor=tk.CENTER)
        self.tree.column("path", width=380, anchor=tk.W)

        vsb = ttk.Scrollbar(tree_frame, orient=tk.VERTICAL, command=self.tree.yview)
        hsb = ttk.Scrollbar(tree_frame, orient=tk.HORIZONTAL, command=self.tree.xview)
        self.tree.configure(yscroll=vsb.set, xscroll=hsb.set)
        self.tree.grid(row=0, column=0, sticky=tk.NSEW)
        vsb.grid(row=0, column=1, sticky=tk.NS)
        hsb.grid(row=1, column=0, sticky=tk.EW)
        tree_frame.rowconfigure(0, weight=1)
        tree_frame.columnconfigure(0, weight=1)

        self.tree.bind("<Double-1>", self._on_tree_double_click)

        btn_row = ttk.Frame(parent)
        btn_row.grid(row=6, column=0, columnspan=7, sticky=tk.EW, pady=(8, 0))
        ttk.Button(btn_row, text="Delete Selected Path",
                   command=self._delete_selected_path).pack(side=tk.LEFT)

        self._refresh_paths_tree()

    def _load_path(self, _=None):
        state, lob, scenario = self.s_state.get(), self.s_lob.get(), self.s_scenario.get()
        if not (state and lob and scenario):
            return
        self.path_var.set(self.parent.config_data.get(config_key(state, lob, scenario), ""))

    def _browse_path(self):
        path = filedialog.asksaveasfilename(
            title="Select or Create Output Template File",
            filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")],
            defaultextension=".xlsx",
            parent=self,
        )
        if path:
            self.path_var.set(path)

    def _save_path(self):
        state, lob, scenario = self.s_state.get(), self.s_lob.get(), self.s_scenario.get()
        path = self.path_var.get().strip()
        if not (state and lob and scenario):
            messagebox.showwarning("Warning", "Please select State, LOB, and Scenario.",
                                   parent=self)
            return
        if not path:
            messagebox.showwarning("Warning", "Please enter or browse for an output path.",
                                   parent=self)
            return
        self.parent.config_data[config_key(state, lob, scenario)] = path
        save_config(self.parent.config_data)
        self._refresh_paths_tree()
        messagebox.showinfo("Saved",
                            f"Path saved for:\n  {state}  /  {lob}  /  {scenario}",
                            parent=self)

    def _delete_selected_path(self):
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Nothing Selected",
                                   "Select a row in the table to delete.", parent=self)
            return
        vals = self.tree.item(selected[0], "values")
        key = config_key(vals[0], vals[1], vals[2])
        if key in self.parent.config_data:
            if messagebox.askyesno(
                    "Confirm Delete",
                    f"Delete path for:\n  {vals[0]}  /  {vals[1]}  /  {vals[2]}?",
                    parent=self):
                del self.parent.config_data[key]
                save_config(self.parent.config_data)
                self._refresh_paths_tree()
                self.path_var.set("")

    def _on_tree_double_click(self, _):
        selected = self.tree.selection()
        if not selected:
            return
        vals = self.tree.item(selected[0], "values")
        self.s_state.set(vals[0])
        self.s_lob.set(vals[1])
        self.s_scenario.set(vals[2])
        self.path_var.set(vals[3])

    def _refresh_paths_tree(self):
        for item in self.tree.get_children():
            self.tree.delete(item)
        for key, value in sorted(self.parent.config_data.items()):
            if "|" not in key:
                continue
            parts = key.split("|")
            if len(parts) == 3:
                self.tree.insert("", tk.END, values=(parts[0], parts[1], parts[2], value))

