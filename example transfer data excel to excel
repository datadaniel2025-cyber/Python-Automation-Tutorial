    def _load_counties(self, _=None):
        state = self.ec_state_var.get()
        if not state:
            return
        counties = self.parent.config_data.get(_EXP_KEY, {}).get(state, [])
        self.county_listbox.delete(0, tk.END)
        for county in sorted(counties):
            self.county_listbox.insert(tk.END, county)

    def _add_county(self):
        state = self.ec_state_var.get()
        if not state:
            messagebox.showwarning("Warning", "Please select a state first.", parent=self)
            return
        name = self.new_county_var.get().strip()
        if not name:
            return
        existing = [self.county_listbox.get(i)
                    for i in range(self.county_listbox.size())]
        if name.lower() in [e.lower() for e in existing]:
            messagebox.showwarning("Duplicate",
                                   f'"{name}" is already in the list.', parent=self)
            return
        inserted = False
        for i, item in enumerate(existing):
            if name.lower() < item.lower():
                self.county_listbox.insert(i, name)
                inserted = True
                break
        if not inserted:
            self.county_listbox.insert(tk.END, name)
        self.new_county_var.set("")
        self.new_county_entry.focus_set()

    def _remove_counties(self):
        selected = list(self.county_listbox.curselection())
        if not selected:
            messagebox.showwarning("Nothing Selected",
                                   "Select one or more counties to remove.", parent=self)
            return
        for idx in reversed(selected):
            self.county_listbox.delete(idx)

    def _clear_counties(self):
        state = self.ec_state_var.get() or "the selected state"
        if self.county_listbox.size() == 0:
            return
        if messagebox.askyesno("Confirm Clear",
                               f"Remove all counties for {state}?", parent=self):
            self.county_listbox.delete(0, tk.END)

    def _save_counties(self):
        state = self.ec_state_var.get()
        if not state:
            messagebox.showwarning("Warning", "Please select a state.", parent=self)
            return
        counties = [self.county_listbox.get(i)
                    for i in range(self.county_listbox.size())]
        if _EXP_KEY not in self.parent.config_data:
            self.parent.config_data[_EXP_KEY] = {}
        self.parent.config_data[_EXP_KEY][state] = counties
        save_config(self.parent.config_data)
        count = len(counties)
        messagebox.showinfo(
            "Saved",
            f"{count} expansion {'county' if count == 1 else 'counties'} "
            f"saved for {state}.",
            parent=self,
        )

