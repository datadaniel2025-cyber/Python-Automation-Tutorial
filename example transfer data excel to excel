import pandas as pd
from pathlib import Path


def clean_column_names(df):
    """
    Clean Excel column names by removing extra spaces
    and converting them to lowercase with underscores.
    """
    df.columns = (
        df.columns
        .str.strip()
        .str.lower()
        .str.replace(" ", "_")
    )
    return df


def main():
    # Input and output file paths
    input_file = Path("sample_data.xlsx")
    output_file = Path("output_summary.xlsx")

    # Read Excel file
    df = pd.read_excel(input_file)

    # Clean column names
    df = clean_column_names(df)

    # Example expected columns:
    # state, county_name, specialty_group_name, membership_count, met_overall

    required_columns = [
        "state",
        "county_name",
        "specialty_group_name",
        "membership_count",
        "met_overall"
    ]

    # Check missing columns
    missing_columns = [col for col in required_columns if col not in df.columns]

    if missing_columns:
        print("Missing required columns:")
        for col in missing_columns:
            print(f"- {col}")
        return

    # Filter only rows where Met Overall = Y
    met_df = df[df["met_overall"].astype(str).str.upper() == "Y"]

    # Create summary by State and Specialty
    summary = (
        df.groupby(["state", "specialty_group_name"])
        .agg(
            total_membership=("membership_count", "sum"),
            total_county_rows=("county_name", "count")
        )
        .reset_index()
    )

    # Create met summary
    met_summary = (
        met_df.groupby(["state", "specialty_group_name"])
        .agg(
            met_county_rows=("county_name", "count")
        )
        .reset_index()
    )

    # Merge summary together
    final_summary = summary.merge(
        met_summary,
        on=["state", "specialty_group_name"],
        how="left"
    )

    # Fill blank met rows with 0
    final_summary["met_county_rows"] = final_summary["met_county_rows"].fillna(0)

    # Calculate adequacy rate
    final_summary["adequacy_rate"] = (
        final_summary["met_county_rows"] / final_summary["total_county_rows"]
    )

    # Export to Excel
    with pd.ExcelWriter(output_file, engine="openpyxl") as writer:
        df.to_excel(writer, sheet_name="Cleaned Data", index=False)
        final_summary.to_excel(writer, sheet_name="Summary", index=False)

    print(f"Automation completed. File saved as: {output_file}")


if __name__ == "__main__":
    main()
