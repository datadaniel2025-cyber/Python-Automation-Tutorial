    def _load_specialties(self, _=None):
        state, lob = self.sf_state_var.get(), self.sf_lob_var.get()
        if not (state and lob):
            return
        key = f"{state}|{lob}"
        entries = self.parent.config_data.get(_SPEC_KEY, {}).get(key, [])
        self.spec_listbox.delete(0, tk.END)
        for entry in sorted(entries):
            self.spec_listbox.insert(tk.END, entry)

    def _add_specialty(self):
        state, lob = self.sf_state_var.get(), self.sf_lob_var.get()
        if not (state and lob):
            messagebox.showwarning("Warning", "Please select State and LOB first.",
                                   parent=self)
            return
        name = self.new_spec_var.get().strip()
        if not name:
            return
        existing = [self.spec_listbox.get(i) for i in range(self.spec_listbox.size())]
        if name.lower() in [e.lower() for e in existing]:
            messagebox.showwarning("Duplicate",
                                   f'"{name}" is already in the list.', parent=self)
            return
        inserted = False
        for i, item in enumerate(existing):
            if name.lower() < item.lower():
                self.spec_listbox.insert(i, name)
                inserted = True
                break
        if not inserted:
            self.spec_listbox.insert(tk.END, name)
        self.new_spec_var.set("")
        self.new_spec_entry.focus_set()

    def _remove_specialties(self):
        selected = list(self.spec_listbox.curselection())
        if not selected:
            messagebox.showwarning("Nothing Selected",
                                   "Select one or more entries to remove.", parent=self)
            return
        for idx in reversed(selected):
            self.spec_listbox.delete(idx)

    def _clear_specialties(self):
        if self.spec_listbox.size() == 0:
            return
        state = self.sf_state_var.get() or "selected state"
        lob = self.sf_lob_var.get() or "selected LOB"
        if messagebox.askyesno("Confirm Clear",
                               f"Remove all specialties for {state} / {lob}?",
                               parent=self):
            self.spec_listbox.delete(0, tk.END)

    def _save_specialties(self):
        state, lob = self.sf_state_var.get(), self.sf_lob_var.get()
        if not (state and lob):
            messagebox.showwarning("Warning", "Please select State and LOB.", parent=self)
            return
        entries = [self.spec_listbox.get(i) for i in range(self.spec_listbox.size())]
        if _SPEC_KEY not in self.parent.config_data:
            self.parent.config_data[_SPEC_KEY] = {}
        key = f"{state}|{lob}"
        if entries:
            self.parent.config_data[_SPEC_KEY][key] = entries
        else:
            self.parent.config_data[_SPEC_KEY].pop(key, None)
        save_config(self.parent.config_data)
        count = len(entries)
        if count:
            msg = (f"{count} specialty {'value' if count == 1 else 'values'} "
                   f"saved for {state} / {lob}.\n\n"
                   f"Only rows matching these specialties will be written to the output.")
        else:
            msg = (f"Specialty filter cleared for {state} / {lob}.\n\n"
                   f"All specialties will be processed for this combination.")
        messagebox.showinfo("Saved", msg, parent=self)


