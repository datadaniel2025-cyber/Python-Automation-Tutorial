# Config keys
_EXP_KEY  = "expansion_counties"   # nested dict: {state: [county, ...]}
_SPEC_KEY = "specialty_filter"     # nested dict: {"state|lob": [specialty, ...]}


def load_config():
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return {}


def save_config(config):
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)


def config_key(state, lob, scenario):
    return f"{state}|{lob}|{scenario}"


def get_expansion_counties(config, state):
    counties = config.get(_EXP_KEY, {}).get(state, [])
    return {c.strip().lower() for c in counties}


def get_specialty_filter(config, state, lob):
    key = f"{state}|{lob}"
    entries = config.get(_SPEC_KEY, {}).get(key)
    if entries is None:
        return None
    return {s.strip().lower() for s in entries}


# ─────────────────────────── Main App Window ────────────────────────────────

class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Excel Template Overwrite Tool")
        self.resizable(False, False)
        self.config_data = load_config()
        self._show_landing()

    def _center(self):
        self.update_idletasks()
        w, h = self.winfo_width(), self.winfo_height()
        sw, sh = self.winfo_screenwidth(), self.winfo_screenheight()
        self.geometry(f"+{(sw - w) // 2}+{(sh - h) // 2}")

    def _show_landing(self):
        for widget in self.winfo_children():
            widget.destroy()
        LandingFrame(self).pack(fill=tk.BOTH, expand=True)
        self._center()

    def _show_tool(self, mode: str):
        for widget in self.winfo_children():
            widget.destroy()
        ToolFrame(self, mode).pack(fill=tk.BOTH, expand=True)
        self._center()


# ─────────────────────────── Landing Page ───────────────────────────────────

class LandingFrame(ttk.Frame):
    def __init__(self, app: App):
        super().__init__(app, padding=36)
        self.app = app
        self._build_ui()

    def _build_ui(self):
        ttk.Label(self, text="Excel Template Overwrite Tool",
                  font=("Segoe UI", 16, "bold")).pack(pady=(0, 6))
        ttk.Label(self, text="Select a tool to get started",
                  font=("Segoe UI", 10), foreground="white").pack(pady=(0, 32))

        card_row = ttk.Frame(self)
        card_row.pack()

        self._make_card(
            card_row,
            title="Access Detail\nSummary Upload",
            description="Upload and overwrite the\nAccess Detail Summary template.",
            mode="access_detail",
        ).pack(side=tk.LEFT, padx=16)

        self._make_card(
            card_row,
            title="Serving Market",
            description="Upload and overwrite the\nServing Market template.",
            mode="serving_market",
        ).pack(side=tk.LEFT, padx=16)

        # bottom spacer
        ttk.Frame(self).pack(pady=8)

    def _make_card(self, parent, title: str, description: str, mode: str):
        BG_NORMAL = "#f5f7fa"
        BG_HOVER  = "#dce8f7"

        card = tk.Frame(parent, width=210, height=170,
                        relief=tk.RAISED, bd=2, cursor="hand2", bg=BG_NORMAL)
        card.pack_propagate(False)

        lbl_title = tk.Label(card, text=title, font=("Segoe UI", 12, "bold"),
                             fg="black", bg=BG_NORMAL, justify=tk.CENTER)
        lbl_title.pack(expand=True, pady=(24, 4))

        lbl_desc = tk.Label(card, text=description, font=("Segoe UI", 9),
                            fg="black", bg=BG_NORMAL, justify=tk.CENTER)
        lbl_desc.pack(expand=True, pady=(0, 20))

        all_widgets = [card, lbl_title, lbl_desc]

        def on_enter(e):
            card.config(bg=BG_HOVER)
            lbl_title.config(bg=BG_HOVER)
            lbl_desc.config(bg=BG_HOVER)

        def on_leave(e):
            card.config(bg=BG_NORMAL)
            lbl_title.config(bg=BG_NORMAL)
            lbl_desc.config(bg=BG_NORMAL)

        def on_click(e):
            self.app._show_tool(mode)

        for w in all_widgets:
            w.bind("<Button-1>", on_click)
            w.bind("<Enter>", on_enter)
            w.bind("<Leave>", on_leave)

        return card


